<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <FlowAuthoringGeneratorPackageAsset>../ForgeTrust.AppSurface.Flow.Generators/bin/$(Configuration)/netstandard2.0/ForgeTrust.AppSurface.Flow.Generators.dll</FlowAuthoringGeneratorPackageAsset>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="ForgeTrust.AppSurface.Flow.DurableTask" />
    <InternalsVisibleTo Include="ForgeTrust.AppSurface.Flow.Tests" />
    <ProjectReference Include="../../ForgeTrust.AppSurface.Core/ForgeTrust.AppSurface.Core.csproj" />
    <ProjectReference Include="../ForgeTrust.AppSurface.Flow.Generators/ForgeTrust.AppSurface.Flow.Generators.csproj"
                      ReferenceOutputAssembly="false"
                      OutputItemType="Analyzer"
                      PrivateAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Options" />
  </ItemGroup>

  <Target Name="ValidateFlowAuthoringGeneratorPackageAsset" BeforeTargets="_GetPackageFiles">
    <Error Condition="!Exists('$(FlowAuthoringGeneratorPackageAsset)')"
           Text="The Flow authoring generator asset '$(FlowAuthoringGeneratorPackageAsset)' is missing. Build ForgeTrust.AppSurface.Flow.Generators before packing ForgeTrust.AppSurface.Flow so the transitive analyzer is included." />
  </Target>

  <Target Name="IncludeFlowAuthoringGeneratorInPackage" BeforeTargets="_GetPackageFiles">
    <ItemGroup>
      <None Include="$(FlowAuthoringGeneratorPackageAsset)"
            Pack="true"
            PackagePath="analyzers/dotnet/cs"
            Visible="false" />
    </ItemGroup>
  </Target>

</Project>
