<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <ImplicitUsings>enable</ImplicitUsings>
    <StaticWebAssetBasePath>_content/$(AssemblyName)</StaticWebAssetBasePath>
    <VerifyRazorWireGeneratedAssetsBeforePack Condition="'$(VerifyRazorWireGeneratedAssetsBeforePack)' == ''">true</VerifyRazorWireGeneratedAssetsBeforePack>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Razor.RuntimeCompilation" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../Auth/ForgeTrust.AppSurface.Auth/ForgeTrust.AppSurface.Auth.csproj" />
    <ProjectReference Include="../../Intelligence/ForgeTrust.AppSurface.Intelligence/ForgeTrust.AppSurface.Intelligence.csproj" />
    <ProjectReference Include="../ForgeTrust.AppSurface.Web/ForgeTrust.AppSurface.Web.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Remove="assets\**\*" />
    <None Remove="assets\**\*" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="wwwroot\background.png" LogicalName="RazorWireEmbeddedAssets/background.png" />
    <EmbeddedResource Include="wwwroot\exampleJsInterop.js" LogicalName="RazorWireEmbeddedAssets/exampleJsInterop.js" />
    <EmbeddedResource Include="wwwroot\razorwire\behavior-kit.js" LogicalName="RazorWireEmbeddedAssets/razorwire/behavior-kit.js" />
    <EmbeddedResource Include="wwwroot\razorwire\form-interactions.js" LogicalName="RazorWireEmbeddedAssets/razorwire/form-interactions.js" />
    <EmbeddedResource Include="wwwroot\razorwire\page-navigation.js" LogicalName="RazorWireEmbeddedAssets/razorwire/page-navigation.js" />
    <EmbeddedResource Include="wwwroot\razorwire\razorwire.islands.js" LogicalName="RazorWireEmbeddedAssets/razorwire/razorwire.islands.js" />
    <EmbeddedResource Include="wwwroot\razorwire\razorwire.js" LogicalName="RazorWireEmbeddedAssets/razorwire/razorwire.js" />
    <EmbeddedResource Include="wwwroot\razorwire\section-copy.js" LogicalName="RazorWireEmbeddedAssets/razorwire/section-copy.js" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>ForgeTrust.RazorWire.Tests</_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>DynamicProxyGenAssembly2</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <Target Name="VerifyRazorWireGeneratedAssetsForPack"
          BeforeTargets="GenerateNuspec"
          Condition="'$(VerifyRazorWireGeneratedAssetsBeforePack)' != 'false'">
    <Message Importance="High" Text="Verifying RazorWire generated browser assets before pack." />
    <Exec Command="pnpm --dir &quot;$(MSBuildProjectDirectory)/..&quot; run assets:razorwire:verify"
          IgnoreExitCode="true">
      <Output TaskParameter="ExitCode" PropertyName="_RazorWireGeneratedAssetsVerifyExitCode" />
    </Exec>
    <Error Condition="'$(_RazorWireGeneratedAssetsVerifyExitCode)' != '0'"
           Text="RWPACK001 RazorWire generated browser assets failed pack verification. Problem: pack would embed stale or unverifiable wwwroot runtime assets. Cause: TypeScript source changed, pnpm dependencies are missing, or the verify script failed. Fix: run `pnpm --dir Web install --frozen-lockfile` if needed, then `pnpm --dir Web run assets:razorwire:build` and `pnpm --dir Web run assets:razorwire:verify`. Emergency bypass only: `/p:VerifyRazorWireGeneratedAssetsBeforePack=false`. Docs: Web/ForgeTrust.RazorWire/Docs/runtime-contract-pipeline.md." />
  </Target>

</Project>
