<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageDescription>Safe opt-in Web Push subscription and delivery rail for AppSurface hosts.</PackageDescription>
    <PackageTags>appsurface;dotnet;aspnetcore;pwa;web-push;vapid</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="ForgeTrust.AppSurface.Web.Push.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../ForgeTrust.AppSurface.Web/ForgeTrust.AppSurface.Web.csproj" />
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Lib.Net.Http.WebPush" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Assets/*.js" />
    <Content Update="package.json" Pack="false" />
    <None Update="THIRD-PARTY-NOTICES.md" Pack="true" PackagePath="" />
  </ItemGroup>
</Project>
