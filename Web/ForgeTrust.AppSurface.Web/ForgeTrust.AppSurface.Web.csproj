<Project Sdk="Microsoft.NET.Sdk.Razor">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
  </PropertyGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="ForgeTrust.AppSurface.Cli"/>
    <InternalsVisibleTo Include="ForgeTrust.AppSurface.Web.Tests"/>
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../../Config/ForgeTrust.AppSurface.Config/ForgeTrust.AppSurface.Config.csproj"/>
    <ProjectReference Include="../../ForgeTrust.AppSurface.Core/ForgeTrust.AppSurface.Core.csproj"/>
  </ItemGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App"/>
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Assets/Pwa/*.js"/>
    <EmbeddedResource Include="Assets/Pwa/*.json"/>
    <Content Update="package.json" CopyToOutputDirectory="Never" CopyToPublishDirectory="Never"/>
  </ItemGroup>
</Project>
