@using ForgeTrust.AppSurface.Web
@using Microsoft.AspNetCore.Http
@model ForgeTrust.AppSurface.Web.BrowserStatusPageModel
@{
    Layout = null;
    var descriptor = BrowserStatusPageDescriptor.TryGet(Model.StatusCode, out var resolvedDescriptor)
        ? resolvedDescriptor
        : BrowserStatusPageDescriptor.NotFound;
    var requestPath = string.IsNullOrWhiteSpace(Model.OriginalPath)
        ? "the requested page"
        : Model.OriginalPath;
    var isDocsPath = Model.StatusCode == StatusCodes.Status404NotFound
        && (requestPath.Equals("/docs", StringComparison.OrdinalIgnoreCase)
            || requestPath.StartsWith("/docs/", StringComparison.OrdinalIgnoreCase));
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@descriptor.Title</title>
    <style>
        :root {
            color-scheme: light;
            font-family: "Segoe UI", sans-serif;
        }

        body {
            margin: 0;
            min-height: 100vh;
            display: grid;
            place-items: center;
            background: linear-gradient(180deg, #f8fafc 0%, #e2e8f0 100%);
            color: #0f172a;
        }

        main {
            width: min(36rem, calc(100% - 2rem));
            padding: 2rem;
            border-radius: 1.5rem;
            background: rgba(255, 255, 255, 0.92);
            box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
        }

        h1 {
            margin-top: 0;
            margin-bottom: 0.75rem;
            font-size: clamp(2rem, 5vw, 3rem);
        }

        p {
            margin: 0 0 1rem;
            line-height: 1.6;
        }

        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.75rem;
            margin: 1.25rem 0;
        }

        a.recovery-link {
            display: inline-flex;
            align-items: center;
            min-height: 2.5rem;
            padding: 0 1rem;
            border-radius: 999px;
            background: #1d4ed8;
            color: #fff;
            font-weight: 700;
            text-decoration: none;
        }

        a.recovery-link.secondary {
            background: #e2e8f0;
            color: #1d4ed8;
        }

        a.recovery-link:hover,
        a.recovery-link:focus-visible {
            text-decoration: underline;
        }

        code {
            padding: 0.2rem 0.45rem;
            border-radius: 999px;
            background: #e2e8f0;
            font-size: 0.95rem;
        }

        .developer-note {
            margin-top: 1.5rem;
            padding-top: 1rem;
            border-top: 1px solid #cbd5e1;
            color: #475569;
            font-size: 0.95rem;
        }
    </style>
</head>
<body>
<main>
    <p>@descriptor.Eyebrow</p>
    <h1>@descriptor.Heading</h1>
    <p>We couldn't open <code>@requestPath</code>. @descriptor.Description</p>
    <nav class="actions" aria-label="Recovery actions">
        <a class="recovery-link" href="@Url.Content("~/")">@descriptor.PrimaryActionText</a>
        @if (isDocsPath)
        {
            <a class="recovery-link secondary" href="@Url.Content("~/docs/search")">Search documentation</a>
        }
    </nav>
    <p class="developer-note">App owners can replace this fallback with <code>@descriptor.AppViewPath</code>. Keep the page useful for users first: show recovery links, explain what happened, and preserve the @Model.StatusCode status.</p>
</main>
</body>
</html>
