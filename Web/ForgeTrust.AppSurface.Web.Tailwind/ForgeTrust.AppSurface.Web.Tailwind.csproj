<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);AddTailwindBuildTaskFilesToPackage</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <Import Project="Tailwind.Common.props" />

  <ItemGroup>
    <Compile Remove="runtimes/**" />
    <EmbeddedResource Remove="runtimes/**" />
    <None Remove="runtimes/**" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CliWrap" />
    <ProjectReference Include="../../ForgeTrust.AppSurface.Core/ForgeTrust.AppSurface.Core.csproj" />
    <ProjectReference Include="../ForgeTrust.AppSurface.Web.Tailwind.Tasks/ForgeTrust.AppSurface.Web.Tailwind.Tasks.csproj" ReferenceOutputAssembly="false" PrivateAssets="all" />
    <ProjectReference Include="runtimes/ForgeTrust.AppSurface.Web.Tailwind.Runtime.win-x64.csproj" />
    <ProjectReference Include="runtimes/ForgeTrust.AppSurface.Web.Tailwind.Runtime.osx-arm64.csproj" />
    <ProjectReference Include="runtimes/ForgeTrust.AppSurface.Web.Tailwind.Runtime.osx-x64.csproj" />
    <ProjectReference Include="runtimes/ForgeTrust.AppSurface.Web.Tailwind.Runtime.linux-arm64.csproj" />
    <ProjectReference Include="runtimes/ForgeTrust.AppSurface.Web.Tailwind.Runtime.linux-x64.csproj" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- This allows the targets file to be bundled in the NuGet package -->
  <ItemGroup>
    <None Include="build\ForgeTrust.AppSurface.Web.Tailwind.targets" Pack="true" PackagePath="build" />
    <None Include="tailwind.version" Pack="true" PackagePath="build" />
    <None Include="$(MSBuildProjectDirectory)\THIRD-PARTY-NOTICES.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <Target Name="AddTailwindBuildTaskFilesToPackage">
    <ItemGroup>
      <TfmSpecificPackageFile Include="..\ForgeTrust.AppSurface.Web.Tailwind.Tasks\bin\$(Configuration)\net10.0\*.dll" PackagePath="build\tasks" />
      <TfmSpecificPackageFile Include="..\ForgeTrust.AppSurface.Web.Tailwind.Tasks\bin\$(Configuration)\net10.0\*.deps.json" PackagePath="build\tasks" />
    </ItemGroup>
  </Target>
</Project>
