<Project>
  <Import Project="../Tailwind.Common.props" />

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <PackageType>Dependency</PackageType>
    <PackageDescription Condition="'$(PackageDescription)' == '' and '$(Description)' != ''">$(Description)</PackageDescription>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <!-- TailwindRid should be set by the importing project -->
    <TailwindBinaryName Condition="'$(TailwindRid)' == 'win-x64'">tailwindcss-windows-x64.exe</TailwindBinaryName>
    <TailwindBinaryName Condition="'$(TailwindRid)' == 'osx-arm64'">tailwindcss-macos-arm64</TailwindBinaryName>
    <TailwindBinaryName Condition="'$(TailwindRid)' == 'osx-x64'">tailwindcss-macos-x64</TailwindBinaryName>
    <TailwindBinaryName Condition="'$(TailwindRid)' == 'linux-x64'">tailwindcss-linux-x64</TailwindBinaryName>
    <TailwindBinaryName Condition="'$(TailwindRid)' == 'linux-arm64'">tailwindcss-linux-arm64</TailwindBinaryName>

    <TailwindDownloadUrl>$(TailwindBaseUrl)/$(TailwindBinaryName)</TailwindDownloadUrl>
    <TailwindDownloadRetries Condition="'$(TailwindDownloadRetries)' == ''">4</TailwindDownloadRetries>
    <TailwindDownloadRetryDelayMilliseconds Condition="'$(TailwindDownloadRetryDelayMilliseconds)' == ''">5000</TailwindDownloadRetryDelayMilliseconds>
    <TailwindRuntimeBinaryResolutionEnabled Condition="'$(TailwindRuntimeBinaryResolutionEnabled)' == ''">true</TailwindRuntimeBinaryResolutionEnabled>
    <_TailwindRuntimeBinaryResolutionEnabledNormalized>$(TailwindRuntimeBinaryResolutionEnabled.Trim().ToLowerInvariant())</_TailwindRuntimeBinaryResolutionEnabledNormalized>
    <_TailwindRuntimeBinaryResolutionEnabledNormalized Condition="'$(_TailwindRuntimeBinaryResolutionEnabledNormalized)' == ''">true</_TailwindRuntimeBinaryResolutionEnabledNormalized>
    <TailwindDownloadCacheRoot Condition="'$(TailwindDownloadCacheRoot)' == '' AND '$(XDG_CACHE_HOME)' != ''">$(XDG_CACHE_HOME)/forgetrust/appsurface/tailwind</TailwindDownloadCacheRoot>
    <TailwindDownloadCacheRoot Condition="'$(TailwindDownloadCacheRoot)' == '' AND '$(LOCALAPPDATA)' != ''">$(LOCALAPPDATA)/ForgeTrust/AppSurface/Tailwind</TailwindDownloadCacheRoot>
    <TailwindDownloadCacheRoot Condition="'$(TailwindDownloadCacheRoot)' == '' AND '$(HOME)' != ''">$(HOME)/.cache/forgetrust/appsurface/tailwind</TailwindDownloadCacheRoot>
    <TailwindDownloadCacheRoot Condition="'$(TailwindDownloadCacheRoot)' == '' AND '$(USERPROFILE)' != ''">$(USERPROFILE)/.cache/forgetrust/appsurface/tailwind</TailwindDownloadCacheRoot>
    <_TailwindDownloadCacheRoot Condition="'$(TailwindDownloadCacheRoot)' != ''">$([MSBuild]::EnsureTrailingSlash('$(TailwindDownloadCacheRoot)'))</_TailwindDownloadCacheRoot>
    <_TailwindCacheDir Condition="'$(_TailwindDownloadCacheRoot)' != ''">$(_TailwindDownloadCacheRoot)tailwind-$(TailwindVersion)/$(TailwindRid)/</_TailwindCacheDir>
    <_TailwindCacheDir Condition="'$(_TailwindCacheDir)' == ''">$(BaseIntermediateOutputPath)$(Configuration)/$(TargetFramework)/tailwind-$(TailwindVersion)/</_TailwindCacheDir>
    <_TailwindBinaryPath>$(_TailwindCacheDir)$(TailwindBinaryName)</_TailwindBinaryPath>
    <ChecksumFile>$(_TailwindCacheDir)sha256sums.txt</ChecksumFile>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);AddTailwindRuntimeBinaryToPackage</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="obj/**/*.cs" />
    <EmbeddedResource Remove="obj/**" />
    <None Remove="obj/**" />
    <None Include="$(MSBuildThisFileDirectory)..\THIRD-PARTY-NOTICES.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <Target
    Name="ValidateTailwindRuntimeBinaryResolutionEnabled"
    BeforeTargets="Build;Pack">
    <Error
      Code="ASTW009"
      Text="ASTW009 Tailwind runtime binary resolution has an invalid value. Problem: TailwindRuntimeBinaryResolutionEnabled is '$(TailwindRuntimeBinaryResolutionEnabled)'. Cause: runtime binary resolution accepts only true, false, or an unset value that defaults to true. Fix: set /p:TailwindRuntimeBinaryResolutionEnabled=true for package validation, runtime package creation, and solution builds that compile Tailwind-consuming projects; use false only for fast non-package paths that do not compile Tailwind-consuming projects. Docs: Web/ForgeTrust.AppSurface.Web.Tailwind/README.md#tailwind-diagnostics."
      Condition="'$(_TailwindRuntimeBinaryResolutionEnabledNormalized)' != 'true' and '$(_TailwindRuntimeBinaryResolutionEnabledNormalized)' != 'false'" />
  </Target>

  <Target
    Name="SkipTailwindRuntimeBinaryResolution"
    DependsOnTargets="ValidateTailwindRuntimeBinaryResolutionEnabled"
    BeforeTargets="Build"
    Condition="'$(_TailwindRuntimeBinaryResolutionEnabledNormalized)' == 'false'">
    <Message
      Importance="High"
      Text="Tailwind runtime binary resolution is disabled for this build. This is valid only for fast non-package paths that do not compile Tailwind-consuming projects; package validation, runtime package creation, and solution builds that compile generated CSS must use /p:TailwindRuntimeBinaryResolutionEnabled=true or leave the property unset." />
  </Target>

  <Target
    Name="ResolveTailwindBinary"
    BeforeTargets="Build"
    DependsOnTargets="ValidateTailwindRuntimeBinaryResolutionEnabled"
    Outputs="$(_TailwindBinaryPath)"
    Condition="'$(_TailwindRuntimeBinaryResolutionEnabledNormalized)' == 'true'">
    <Error Text="TailwindRid must be set by the importing project."
           Condition="'$(TailwindRid)' == ''" />
    <Error Text="Unsupported TailwindRid '$(TailwindRid)'. No TailwindBinaryName mapping was found."
           Condition="'$(TailwindRid)' != '' and '$(TailwindBinaryName)' == ''" />

    <MakeDir Directories="$(_TailwindCacheDir)" Condition="!Exists('$(_TailwindCacheDir)')" />

    <DownloadFile
      SourceUrl="$(TailwindSumsUrl)"
      DestinationFolder="$(_TailwindCacheDir)"
      DestinationFileName="sha256sums.txt"
      Retries="$(TailwindDownloadRetries)"
      RetryDelayMilliseconds="$(TailwindDownloadRetryDelayMilliseconds)"
      Condition="!Exists('$(ChecksumFile)')" />

    <FindChecksum ChecksumFile="$(ChecksumFile)" BinaryName="$(TailwindBinaryName)">
      <Output TaskParameter="Hash" PropertyName="ExpectedHash" />
    </FindChecksum>

    <Error Text="Could not find expected SHA-256 hash for '$(TailwindBinaryName)' in '$(ChecksumFile)'." Condition="'$(ExpectedHash)' == ''" />

    <DownloadFile
      SourceUrl="$(TailwindDownloadUrl)"
      DestinationFolder="$(_TailwindCacheDir)"
      DestinationFileName="$(TailwindBinaryName)"
      Retries="$(TailwindDownloadRetries)"
      RetryDelayMilliseconds="$(TailwindDownloadRetryDelayMilliseconds)"
      Condition="!Exists('$(_TailwindBinaryPath)')" />

    <GetFileHash Files="$(_TailwindBinaryPath)" Algorithm="SHA256">
      <Output TaskParameter="Items" ItemName="ComputedHashes" />
    </GetFileHash>

    <PropertyGroup>
      <_ComputedHash>%(ComputedHashes.FileHash)</_ComputedHash>
    </PropertyGroup>

    <Message Importance="High" Text="Tailwind CLI: Expected Hash: [$(ExpectedHash.ToLower())]" />
    <Message Importance="High" Text="Tailwind CLI: Computed Hash: [$(_ComputedHash.ToLower())]" />

    <Error Text="Tailwind CLI checksum mismatch! Expected: $(ExpectedHash), Computed: $(_ComputedHash)" Condition="'$(ExpectedHash.ToLower())' != '$(_ComputedHash.ToLower())'" />

    <Exec Command="chmod +x &quot;$(_TailwindBinaryPath)&quot;" Condition="!$([MSBuild]::IsOSPlatform('Windows'))" />
  </Target>

  <Target
    Name="ErrorIfTailwindRuntimePackageCreatedWithoutBinaryResolution"
    DependsOnTargets="ValidateTailwindRuntimeBinaryResolutionEnabled"
    BeforeTargets="AddTailwindRuntimeBinaryToPackage">
    <Error
      Code="ASTW010"
      Text="ASTW010 Tailwind runtime binary resolution is disabled during runtime package creation. Problem: this runtime package cannot be packed without its native Tailwind binary. Cause: TailwindRuntimeBinaryResolutionEnabled=false was passed to pack. Fix: rerun restore, build, and pack package-validation paths with /p:TailwindRuntimeBinaryResolutionEnabled=true. Docs: Web/ForgeTrust.AppSurface.Web.Tailwind/README.md#tailwind-diagnostics."
      Condition="'$(_TailwindRuntimeBinaryResolutionEnabledNormalized)' == 'false'" />
  </Target>

  <Target
    Name="AddTailwindRuntimeBinaryToPackage"
    DependsOnTargets="ValidateTailwindRuntimeBinaryResolutionEnabled;ErrorIfTailwindRuntimePackageCreatedWithoutBinaryResolution;ResolveTailwindBinary">
    <Error
      Code="ASTW011"
      Text="ASTW011 Resolved Tailwind runtime binary is missing. Problem: the runtime package payload file does not exist at '$(_TailwindBinaryPath)'. Cause: binary resolution did not produce the expected file or a stale intermediate output was removed before packing. Fix: rerun package validation with /p:TailwindRuntimeBinaryResolutionEnabled=true, delete stale obj output if needed, and check TailwindBaseUrl/TailwindSumsUrl download settings. Docs: Web/ForgeTrust.AppSurface.Web.Tailwind/README.md#tailwind-diagnostics."
      Condition="!Exists('$(_TailwindBinaryPath)')" />
    <ItemGroup>
      <TfmSpecificPackageFile Include="$(_TailwindBinaryPath)" PackagePath="runtimes/$(TailwindRid)/native" />
    </ItemGroup>
  </Target>
</Project>
