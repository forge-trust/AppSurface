<Project>
  <PropertyGroup>
    <TailwindEnabled Condition="'$(TailwindEnabled)' == ''">true</TailwindEnabled>
    <TailwindInputPath Condition="'$(TailwindInputPath)' == ''">wwwroot/css/app.css</TailwindInputPath>
    <TailwindOutputPath Condition="'$(TailwindOutputPath)' == ''">wwwroot/css/site.gen.css</TailwindOutputPath>
    <TailwindCliPath Condition="'$(TailwindCliPath)' == ''"></TailwindCliPath>
    <_TailwindVersionFilePackage>$(MSBuildThisFileDirectory)tailwind.version</_TailwindVersionFilePackage>
    <_TailwindVersionFileSource>$(MSBuildThisFileDirectory)..\tailwind.version</_TailwindVersionFileSource>
    <_TailwindVersionFile Condition="Exists('$(_TailwindVersionFilePackage)')">$(_TailwindVersionFilePackage)</_TailwindVersionFile>
    <_TailwindVersionFile Condition="'$(_TailwindVersionFile)' == '' and Exists('$(_TailwindVersionFileSource)')">$(_TailwindVersionFileSource)</_TailwindVersionFile>
    <_TailwindTaskAssemblyPackage>$(MSBuildThisFileDirectory)tasks\ForgeTrust.AppSurface.Web.Tailwind.Tasks.dll</_TailwindTaskAssemblyPackage>
    <_TailwindTaskAssemblySourceProject>$(MSBuildThisFileDirectory)..\..\ForgeTrust.AppSurface.Web.Tailwind.Tasks\ForgeTrust.AppSurface.Web.Tailwind.Tasks.csproj</_TailwindTaskAssemblySourceProject>
    <_TailwindTaskTargetFramework>net10.0</_TailwindTaskTargetFramework>
    <_TailwindTaskAssemblySource>$(MSBuildThisFileDirectory)..\..\ForgeTrust.AppSurface.Web.Tailwind.Tasks\bin\$(Configuration)\$(_TailwindTaskTargetFramework)\ForgeTrust.AppSurface.Web.Tailwind.Tasks.dll</_TailwindTaskAssemblySource>
    <_TailwindTaskAssemblySourceDisplay Condition="Exists('$(_TailwindTaskAssemblySourceProject)')">$(_TailwindTaskAssemblySource)</_TailwindTaskAssemblySourceDisplay>
    <_TailwindTaskAssembly Condition="Exists('$(_TailwindTaskAssemblyPackage)')">$(_TailwindTaskAssemblyPackage)</_TailwindTaskAssembly>
    <_TailwindTaskAssembly Condition="'$(_TailwindTaskAssembly)' == '' and Exists('$(_TailwindTaskAssemblySourceProject)')">$(_TailwindTaskAssemblySource)</_TailwindTaskAssembly>
    <_TailwindOutputPathNormalized>$([System.String]::Copy('$(TailwindOutputPath)').Replace('\', '/'))</_TailwindOutputPathNormalized>
    <_TailwindOutputPathNormalized Condition="$([System.String]::Copy('$(_TailwindOutputPathNormalized)').StartsWith('./'))">$([System.String]::Copy('$(_TailwindOutputPathNormalized)').Substring(2))</_TailwindOutputPathNormalized>
    <_TailwindOutputIsWebRootAsset>false</_TailwindOutputIsWebRootAsset>
    <_TailwindOutputIsWebRootAsset Condition="'$(_TailwindOutputPathNormalized)' == 'wwwroot' or $([System.String]::Copy('$(_TailwindOutputPathNormalized)').StartsWith('wwwroot/'))">true</_TailwindOutputIsWebRootAsset>
    <_TailwindUsesSdkDefaultContentItems>true</_TailwindUsesSdkDefaultContentItems>
    <_TailwindUsesSdkDefaultContentItems Condition="'$(EnableDefaultItems)' == 'false' or '$(EnableDefaultContentItems)' == 'false'">false</_TailwindUsesSdkDefaultContentItems>
  </PropertyGroup>

  <ItemGroup>
    <_TailwindTemplates Include="**/*.cshtml;**/*.html;**/*.razor" Exclude="bin/**;obj/**" />
    <_TailwindConfigs Include="tailwind.config.js" Condition="Exists('tailwind.config.js')" />
    <_TailwindConfigs Include="postcss.config.js" Condition="Exists('postcss.config.js')" />
  </ItemGroup>

  <UsingTask TaskName="ForgeTrust.AppSurface.Web.Tailwind.Tasks.RunTailwindBuildTask"
             AssemblyFile="$(_TailwindTaskAssembly)"
             Condition="'$(_TailwindTaskAssembly)' != '' and (Exists('$(_TailwindTaskAssembly)') or '$(_TailwindTaskAssembly)' == '$(_TailwindTaskAssemblySource)')" />

  <ItemGroup Condition="'$(TailwindEnabled)' == 'true' and '$(_TailwindOutputIsWebRootAsset)' == 'true' and ('$(_TailwindUsesSdkDefaultContentItems)' == 'false' or !Exists('$(TailwindOutputPath)'))">
    <!--
      Declare the generated output as project content up front so a clean build can include it in the
      static web asset manifest once RunTailwindBuild materializes the file under wwwroot/. Keep the
      explicit item for consumers that disable the SDK's default content globs because they do not pick
      up existing wwwroot files on subsequent incremental builds.
    -->
    <Content Include="$(TailwindOutputPath)">
      <CopyToOutputDirectory>Never</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <Pack>false</Pack>
      <Visible>false</Visible>
    </Content>
  </ItemGroup>

  <Target Name="ValidateTailwindBuildPaths"
          BeforeTargets="RunTailwindBuild"
          Condition="'$(TailwindEnabled)' == 'true' AND Exists('$(TailwindInputPath)')">
    <PropertyGroup>
      <_TailwindInputPathFull>$([System.IO.Path]::GetFullPath('$(TailwindInputPath)', '$(MSBuildProjectDirectory)'))</_TailwindInputPathFull>
      <_TailwindOutputPathFull>$([System.IO.Path]::GetFullPath('$(TailwindOutputPath)', '$(MSBuildProjectDirectory)'))</_TailwindOutputPathFull>
      <_TailwindInputPathComparable>$(_TailwindInputPathFull)</_TailwindInputPathComparable>
      <_TailwindOutputPathComparable>$(_TailwindOutputPathFull)</_TailwindOutputPathComparable>
      <_TailwindInputPathComparable Condition="$([MSBuild]::IsOSPlatform('Windows'))">$([System.String]::Copy('$(_TailwindInputPathFull)').ToUpperInvariant())</_TailwindInputPathComparable>
      <_TailwindOutputPathComparable Condition="$([MSBuild]::IsOSPlatform('Windows'))">$([System.String]::Copy('$(_TailwindOutputPathFull)').ToUpperInvariant())</_TailwindOutputPathComparable>
      <_TailwindSameInputOutput>$([System.String]::Copy('$(_TailwindInputPathComparable)').Equals('$(_TailwindOutputPathComparable)'))</_TailwindSameInputOutput>
    </PropertyGroup>

    <Error Text="ASTW008: TailwindInputPath and TailwindOutputPath must point to different files. Cause: Tailwind would overwrite its own source input. Fix: Set TailwindOutputPath to a different generated CSS file. See: https://github.com/forge-trust/AppSurface/tree/main/Web/ForgeTrust.AppSurface.Web.Tailwind#tailwind-diagnostics"
           Condition="'$(_TailwindSameInputOutput)' == 'True'" />
  </Target>

  <Target Name="BuildTailwindSourceTaskAssembly"
          BeforeTargets="RunTailwindBuild"
          Condition="'$(TailwindEnabled)' == 'true' AND Exists('$(TailwindInputPath)') AND '$(_TailwindTaskAssembly)' == '$(_TailwindTaskAssemblySource)' AND !Exists('$(_TailwindTaskAssemblySource)')">
    <MSBuild Projects="$(_TailwindTaskAssemblySourceProject)"
             Targets="Build"
             Properties="Configuration=$(Configuration);TargetFramework=$(_TailwindTaskTargetFramework)" />
  </Target>

  <Target Name="RunTailwindBuild" AfterTargets="ResolveProjectReferences" BeforeTargets="PrepareResources;Compile"
          Condition="'$(TailwindEnabled)' == 'true' AND Exists('$(TailwindInputPath)')"
          Inputs="$(TailwindInputPath);@(_TailwindTemplates);@(_TailwindConfigs)"
          Outputs="$(TailwindOutputPath)">
    <PropertyGroup>
      <!-- Source-tree consumers import only this targets file, so resolve TailwindVersion here as well. -->
      <TailwindVersion Condition="'$(TailwindVersion)' == '' and Exists('$(_TailwindVersionFile)')">$([System.Text.RegularExpressions.Regex]::Match($([System.IO.File]::ReadAllText('$(_TailwindVersionFile)')), '^[^\r\n]+').Value)</TailwindVersion>

      <_TailwindTaskAssemblyDisplay Condition="'$(_TailwindTaskAssembly)' != ''">$(_TailwindTaskAssembly)</_TailwindTaskAssemblyDisplay>
      <_TailwindTaskAssemblyDisplay Condition="'$(_TailwindTaskAssemblyDisplay)' == '' and '$(_TailwindTaskAssemblySourceDisplay)' != ''">$(_TailwindTaskAssemblySourceDisplay)</_TailwindTaskAssemblyDisplay>
      <_TailwindTaskAssemblyDisplay Condition="'$(_TailwindTaskAssemblyDisplay)' == ''">$(_TailwindTaskAssemblyPackage)</_TailwindTaskAssemblyDisplay>
    </PropertyGroup>

    <Error Text="ASTW005: Tailwind MSBuild task assembly could not be found. Cause: '$(_TailwindTaskAssemblyDisplay)' does not exist. Fix: Restore and build ForgeTrust.AppSurface.Web.Tailwind.Tasks, or consume the packed ForgeTrust.AppSurface.Web.Tailwind package. See: https://github.com/forge-trust/AppSurface/tree/main/Web/ForgeTrust.AppSurface.Web.Tailwind#tailwind-diagnostics"
           Condition="'$(_TailwindTaskAssembly)' == '' or !Exists('$(_TailwindTaskAssembly)')" />

    <ForgeTrust.AppSurface.Web.Tailwind.Tasks.RunTailwindBuildTask
      ProjectDirectory="$(MSBuildProjectDirectory)"
      InputPath="$(TailwindInputPath)"
      OutputPath="$(TailwindOutputPath)"
      TailwindCliPath="$(TailwindCliPath)"
      TailwindVersion="$(TailwindVersion)"
      TargetsDirectory="$(MSBuildThisFileDirectory)"
      Configuration="$(Configuration)"
      TargetFramework="$(TargetFramework)"
      TailwindTargetRid="$(TailwindTargetRid)" />
  </Target>
</Project>
