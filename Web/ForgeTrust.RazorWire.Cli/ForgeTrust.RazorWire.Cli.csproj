<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable Condition="'$(EnableRazorWireCliToolPackaging)' != 'true'">false</IsPackable>
    <IsPackable Condition="'$(EnableRazorWireCliToolPackaging)' == 'true'">true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>razorwire</ToolCommandName>
    <PackageId>ForgeTrust.RazorWire.Cli</PackageId>
    <PackageDescription>Command-line export tooling for RazorWire applications.</PackageDescription>
    <PackageTags>appsurface;razorwire;static-site;cli;dotnet-tool</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../ForgeTrust.AppSurface.Web/ForgeTrust.AppSurface.Web.csproj" />
    <ProjectReference Include="../ForgeTrust.RazorWire/ForgeTrust.RazorWire.csproj" />
    <ProjectReference Include="../../Console/ForgeTrust.AppSurface.Console/ForgeTrust.AppSurface.Console.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="ForgeTrust.RazorWire.Cli.Tests" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="CliFx" />
  </ItemGroup>

</Project>
