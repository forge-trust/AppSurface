@model ForgeTrust.AppSurface.Docs.Models.AppSurfaceDocsRouteInspectorResponse
@{
    ViewData["Title"] = "Route Inspector";
    var probeStatusClass = Model.Probe?.Kind switch
    {
        "Canonical" => "border-emerald-400/35 bg-emerald-950/35 text-emerald-100",
        "AliasRedirect" => "border-sky-400/35 bg-sky-950/35 text-sky-100",
        "ReservedRoute" => "border-amber-400/35 bg-amber-950/35 text-amber-100",
        "InvalidInput" or "NotFound" => "border-rose-400/40 bg-rose-950/40 text-rose-100",
        _ => "border-slate-600 bg-slate-900/70 text-slate-100"
    };
}

<div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <header class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-[#14b8a6]">AppSurface Docs</p>
        <h1 class="docs-gradient-title mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">Route Inspector</h1>
        <p class="mt-4 text-base leading-7 text-slate-300">
            Inspect the current route manifest and probe how one docs path resolves without exposing host-local filesystem paths.
        </p>
    </header>

    <section class="mt-8" aria-labelledby="route-probe-heading">
        <h2 id="route-probe-heading" class="text-xl font-semibold text-white">Probe a Path</h2>
        <form method="get" class="mt-4 flex flex-col gap-3 sm:flex-row">
            <label class="sr-only" for="route-inspector-path">Route path</label>
            <input id="route-inspector-path"
                   class="min-h-11 flex-1 rounded-md border border-[#263650] bg-[#050b17] px-3 py-2 text-sm text-slate-100 outline-none transition focus:border-[#14b8a6] focus:ring-2 focus:ring-[#14b8a6]/30"
                   name="path"
                   value="@Model.Probe?.InputPath"
                   placeholder="packages/README.md or /docs/packages"
                   autocomplete="off" />
            <button type="submit"
                    class="min-h-11 rounded-md border border-[#2563eb] bg-[#2563eb] px-4 py-2 text-sm font-semibold text-white transition hover:bg-[#1d4ed8] focus:outline-none focus:ring-2 focus:ring-[#14b8a6]/40">
                Probe
            </button>
        </form>

        @if (Model.Probe is not null)
        {
            <div class="mt-4 rounded-lg border p-4 @probeStatusClass">
                <div class="flex flex-wrap items-center gap-2">
                    <span class="text-sm font-semibold">@Model.Probe.Kind</span>
                    @if (!string.IsNullOrWhiteSpace(Model.Probe.NormalizedPath))
                    {
                        <code class="rounded border border-white/10 bg-black/20 px-2 py-0.5 text-xs">@Model.Probe.NormalizedPath</code>
                    }
                </div>
                <p class="mt-2 text-sm leading-6">@Model.Probe.Message</p>
                @if (!string.IsNullOrWhiteSpace(Model.Probe.CanonicalLiveUrl))
                {
                    <p class="mt-3 text-sm">
                        Canonical:
                        <a class="font-semibold underline decoration-white/30 underline-offset-4 hover:decoration-white"
                           href="@Url.PathBaseAware(Model.Probe.CanonicalLiveUrl)">
                            @Model.Probe.CanonicalLiveUrl
                        </a>
                    </p>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Probe.SourcePath))
                {
                    <p class="mt-1 text-sm">Source: <code class="text-xs">@Model.Probe.SourcePath</code></p>
                }
            </div>
        }
    </section>

    <section class="mt-8" aria-labelledby="routes-heading">
        <div class="flex flex-wrap items-end justify-between gap-3">
            <div>
                <h2 id="routes-heading" class="text-xl font-semibold text-white">Canonical Routes</h2>
                <p class="mt-1 text-sm text-slate-400">@Model.Entries.Count route entries in this snapshot.</p>
            </div>
        </div>
        <div class="mt-4 overflow-x-auto rounded-lg border border-[#1b2a43]">
            <table class="min-w-full divide-y divide-slate-800 text-left text-sm">
                <thead class="bg-slate-950/70 text-xs uppercase tracking-[0.16em] text-slate-500">
                    <tr>
                        <th scope="col" class="px-4 py-3 font-semibold">Canonical</th>
                        <th scope="col" class="px-4 py-3 font-semibold">Source</th>
                        <th scope="col" class="px-4 py-3 font-semibold">Recovery Aliases</th>
                        <th scope="col" class="px-4 py-3 font-semibold">Declared Aliases</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800 bg-slate-950/30">
                    @foreach (var entry in Model.Entries)
                    {
                        <tr>
                            <td class="min-w-56 px-4 py-3 align-top">
                                <a class="font-semibold text-slate-100 underline decoration-slate-600 underline-offset-4 hover:decoration-[#14b8a6]"
                                   href="@Url.PathBaseAware(entry.CanonicalLiveUrl)">
                                    @entry.CanonicalRoutePath
                                </a>
                            </td>
                            <td class="min-w-56 px-4 py-3 align-top text-slate-300">
                                <code class="text-xs">@entry.SourcePath</code>
                            </td>
                            <td class="min-w-72 px-4 py-3 align-top">
                                @if (entry.RecoveryAliases.Count == 0)
                                {
                                    <span class="text-slate-500">None</span>
                                }
                                else
                                {
                                    <ul class="space-y-1">
                                        @foreach (var alias in entry.RecoveryAliases)
                                        {
                                            <li>
                                                <a class="text-slate-300 underline decoration-slate-700 underline-offset-4 hover:decoration-[#14b8a6]"
                                                   href="@Url.PathBaseAware(alias.LiveUrl)">
                                                    @alias.RoutePath
                                                </a>
                                                <span class="ml-2 text-xs text-slate-500">@alias.Kind</span>
                                            </li>
                                        }
                                    </ul>
                                }
                            </td>
                            <td class="min-w-72 px-4 py-3 align-top">
                                @if (entry.DeclaredAliases.Count == 0)
                                {
                                    <span class="text-slate-500">None</span>
                                }
                                else
                                {
                                    <ul class="space-y-1">
                                        @foreach (var alias in entry.DeclaredAliases)
                                        {
                                            <li>
                                                <a class="text-slate-300 underline decoration-slate-700 underline-offset-4 hover:decoration-[#14b8a6]"
                                                   href="@Url.PathBaseAware(alias.LiveUrl)">
                                                    @alias.RoutePath
                                                </a>
                                                <span class="ml-2 text-xs text-slate-500">@alias.Kind</span>
                                            </li>
                                        }
                                    </ul>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    @if (Model.Diagnostics.Count > 0)
    {
        <section class="mt-8" aria-labelledby="route-diagnostics-heading">
            <h2 id="route-diagnostics-heading" class="text-xl font-semibold text-white">Diagnostics</h2>
            <ul class="mt-4 space-y-3">
                @foreach (var diagnostic in Model.Diagnostics)
                {
                    <li class="rounded-lg border border-[#1b2a43] bg-[#050b17]/45 p-4">
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="text-sm font-semibold text-white">@diagnostic.Code</span>
                            <span class="rounded-full border border-slate-700 px-2 py-0.5 text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-slate-400">@diagnostic.Severity</span>
                            @if (!string.IsNullOrWhiteSpace(diagnostic.HarvesterType))
                            {
                                <span class="text-xs text-slate-500">@diagnostic.HarvesterType</span>
                            }
                        </div>
                        <p class="mt-3 text-sm leading-6 text-slate-300">@diagnostic.Problem</p>
                        @if (!string.IsNullOrWhiteSpace(diagnostic.Fix))
                        {
                            <p class="mt-2 text-sm leading-6 text-slate-400">@diagnostic.Fix</p>
                        }
                    </li>
                }
            </ul>
        </section>
    }
</div>
