@model ForgeTrust.AppSurface.Docs.Models.SearchPageViewModel
@inject ForgeTrust.AppSurface.Docs.Services.DocsUrlBuilder DocsUrlBuilder
@{
    const string FailureLinkClass = "grid gap-1 rounded-lg border docs-token-border-muted docs-token-bg-raised px-[0.95rem] py-[0.85rem] no-underline transition-colors docs-token-hover-border-accent docs-token-hover-bg-raised";
}

<div id="docs-search-page" class="docs-search-page">
    <header class="grid gap-[0.55rem]">
        <p class="m-0 text-[0.72rem] font-semibold uppercase tracking-[0.16em] docs-token-text-accent">AppSurface Search</p>
        <h1 class="docs-gradient-title m-0 text-[clamp(2rem,4vw,3rem)] font-bold leading-[1.02]">@Model.Title</h1>
        <p class="m-0 max-w-[52rem] text-base leading-[1.6] text-slate-400">@Model.Orientation</p>
    </header>

    <div class="grid items-start gap-[0.85rem] md:grid-cols-[minmax(0,1fr)_auto]">
        <div class="min-w-0">
            <label for="docs-search-page-input" class="sr-only">Search query</label>
            <input id="docs-search-page-input"
                   type="search"
                   placeholder="@Model.SearchPlaceholder"
                   autocomplete="off"
                   spellcheck="false"
                   aria-describedby="docs-search-page-status"
                   aria-controls="docs-search-page-results"
                   aria-label="Search query" />
        </div>
        <button id="docs-search-page-filters-toggle"
                class="docs-search-page-filters-toggle"
                type="button"
                aria-controls="docs-search-page-filters-panel"
                aria-expanded="false">
            Filters
        </button>
    </div>

    <p id="docs-search-page-status" class="docs-search-page-status" aria-live="polite">
        Loading search index...
    </p>

    <div id="docs-search-page-active-filters" class="docs-search-page-active-filters" hidden></div>

    <section id="docs-search-page-filters-panel"
             class="docs-search-page-filters-panel"
             aria-label="Search filters">
        <div id="docs-search-page-filters" class="docs-search-page-filters"></div>
    </section>

    <section id="docs-search-page-starter"
             class="docs-search-page-starter"
             aria-label="Search suggestions">
        <p class="docs-search-page-starter-copy">@Model.StarterHint</p>
        <div class="flex flex-wrap gap-[0.6rem]">
            @foreach (var query in Model.SuggestedQueries)
            {
                var queryHref = Url.PathBaseAware($"{DocsUrlBuilder.Routes.Search}?q={Uri.EscapeDataString(query)}");
                <a class="docs-search-page-starter-chip"
                   href="@queryHref"
                   data-rw-search-suggestion="@query">
                    @query
                </a>
            }
        </div>
        <div id="docs-search-page-starter-docs"
             class="docs-search-page-starter-docs"
             hidden></div>
    </section>

    <section id="docs-search-page-recovery"
             class="docs-search-page-recovery"
             aria-label="Browse documentation entry points">
        <h2 class="docs-search-page-section-title">Browse while search loads</h2>
        <p class="m-0 text-slate-300 leading-[1.55]">
            These links are rendered by the server, so they stay useful for crawlers, no-JS readers, and failed index loads.
        </p>
        <div class="docs-search-page-recovery-links">
            @foreach (var link in Model.FailureFallbackLinks)
            {
                var resolvedHref = Url.PathBaseAware(link.Href);
                if (link.UsesDocsFrame)
                {
                    <a class="@FailureLinkClass docs-search-page-recovery-link"
                       href="@resolvedHref"
                       data-rw-recovery-link-kind="server_fallback"
                       data-rw-recovery-source-state="loading"
                       data-turbo-frame="doc-content"
                       data-turbo-action="advance">
                        <span class="text-[0.95rem] font-semibold docs-token-text-accent">@link.Title</span>
                        <span class="text-[0.82rem] leading-[1.45] text-slate-400">@link.Description</span>
                    </a>
                }
                else
                {
                    <a class="@FailureLinkClass docs-search-page-recovery-link"
                       href="@resolvedHref"
                       data-rw-recovery-link-kind="server_fallback"
                       data-rw-recovery-source-state="loading"
                       data-turbo-frame="_top">
                        <span class="text-[0.95rem] font-semibold docs-token-text-accent">@link.Title</span>
                        <span class="text-[0.82rem] leading-[1.45] text-slate-400">@link.Description</span>
                    </a>
                }
            }
        </div>
    </section>

    <section id="docs-search-page-failure"
             class="docs-search-page-failure"
             hidden
             aria-live="polite">
    </section>

    <template id="docs-search-page-failure-template">
        <h2 class="docs-search-page-section-title">Search is temporarily unavailable</h2>
        <p class="m-0 text-slate-300 leading-[1.55]">
            Search index could not be loaded. You can retry or keep moving with the browse links already on this page.
        </p>
        <div class="flex flex-wrap gap-3">
            <button id="docs-search-page-retry"
                    class="docs-search-page-retry"
                    type="button">
                Retry
            </button>
        </div>
    </template>

    <div id="docs-search-page-results-meta" class="docs-search-page-results-meta" hidden></div>

    <section id="docs-search-page-results"
             class="docs-search-page-results"
             aria-label="Search results"
             aria-busy="true">
        @for (var index = 0; index < 3; index++)
        {
            <article class="docs-search-result docs-search-result-skeleton" aria-hidden="true">
                <div class="docs-search-skeleton docs-search-skeleton-title"></div>
                <div class="docs-search-skeleton docs-search-skeleton-meta"></div>
                <div class="docs-search-skeleton docs-search-skeleton-line"></div>
                <div class="docs-search-skeleton docs-search-skeleton-line docs-search-skeleton-line-short"></div>
            </article>
        }
    </section>
</div>
