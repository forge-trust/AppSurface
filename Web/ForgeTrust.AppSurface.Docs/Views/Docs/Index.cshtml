@model ForgeTrust.AppSurface.Docs.Models.DocLandingViewModel
@inject ForgeTrust.AppSurface.Docs.AppSurfaceDocsAssetPathResolver AssetPathResolver
@inject ForgeTrust.AppSurface.Docs.Services.AppSurfaceDocsIdentityResolver IdentityResolver
@{
    ViewData["Title"] = "Documentation Index";
    var docsIdentity = IdentityResolver.Identity;
    var docsBrandIconUrl = docsIdentity.Logo is null
        ? Url.Content(AssetPathResolver.BrandIconPath)
        : Url.PathBaseAware(docsIdentity.Logo.Path);
}

<div class="mx-auto max-w-5xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <div class="mb-8 docs-hero-panel rounded-lg p-5 sm:p-6">
        <div class="relative flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
            <div class="max-w-3xl">
                <p class="text-xs font-semibold uppercase tracking-[0.18em] docs-token-text-accent">ForgeTrust AppSurface</p>
                @if (string.Equals(Model.Heading, docsIdentity.DisplayName, StringComparison.Ordinal))
                {
                    @ForgeTrust.AppSurface.Docs.Services.AppSurfaceDocsWordmarkHtml.Render(docsIdentity, "docs-wordmark mt-3 text-3xl sm:text-4xl", "h1")
                }
                else
                {
                    <h1 class="docs-gradient-title mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">@Model.Heading</h1>
                }
                <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">@Model.Description</p>
            </div>
            <div class="flex items-center gap-4 sm:flex-col sm:items-end">
                <img class="docs-brand-mark docs-brand-mark--lg" src="@docsBrandIconUrl" alt="" aria-hidden="true" />
                <span class="docs-brand-kicker">Documentation</span>
            </div>
        </div>
    </div>

    <section class="docs-surface-panel rounded-lg p-6 sm:p-8">
        <div class="flex flex-col gap-4 border-b docs-token-border-muted pb-5 sm:flex-row sm:items-end sm:justify-between">
            <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] docs-token-text-accent">Start Here</p>
                <h2 class="mt-2 text-2xl font-semibold tracking-tight text-white">Follow the proof path first.</h2>
                <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-300">
                    Understand what the system is for, see it working, then choose the next implementation route with context.
                </p>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.StartHereHref))
            {
                <a href="@Url.PathBaseAware(Model.StartHereHref)"
                   aria-label="Browse Start Here"
                   class="inline-flex min-h-11 items-center gap-2 self-start rounded-full border docs-token-border-accent docs-token-bg-active px-4 py-2 text-sm font-semibold docs-token-text-info-muted transition-colors docs-token-hover-border-accent docs-token-hover-bg-accent-fill">
                    Start Here
                    <svg class="h-4 w-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                        <circle cx="10" cy="10" r="7"></circle>
                        <path d="M8.5 6.75L11.75 10 8.5 13.25"></path>
                    </svg>
                </a>
            }
        </div>

        @if (Model.HasFeaturedPages)
        {
            <div class="mt-6 space-y-8">
                @foreach (var featuredGroup in Model.FeaturedPageGroups.Where(group => group.Pages.Count > 0))
                {
                    <section class="border-t docs-token-border-muted pt-5 first:border-t-0 first:pt-0">
                        <div class="max-w-3xl">
                            <h3 class="text-base font-semibold text-white">@featuredGroup.Label</h3>
                            @if (!string.IsNullOrWhiteSpace(featuredGroup.Summary))
                            {
                                <p class="mt-2 text-sm leading-6 text-slate-300">@featuredGroup.Summary</p>
                            }
                        </div>
                        <ul class="mt-4 space-y-3">
                            @foreach (var featuredPage in featuredGroup.Pages)
                            {
                                <li>
                                    <a href="@Url.PathBaseAware(featuredPage.Href)"
                                       data-turbo-frame="doc-content"
                                       data-turbo-action="advance"
                                       class="group block rounded-lg border docs-token-border-muted docs-token-bg-panel-faint px-5 py-4 transition-colors docs-token-hover-border-accent docs-token-hover-bg-panel">
                                        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                                            <div class="min-w-0 flex-1">
                                                <div class="flex flex-wrap items-center gap-3">
                                                    <p class="text-xs font-semibold uppercase tracking-[0.16em] docs-token-text-accent">@featuredPage.Question</p>
                                                    @if (featuredPage.PageTypeBadge is not null)
                                                    {
                                                        <span class="docs-page-badge docs-page-badge--@featuredPage.PageTypeBadge.Variant">
                                                            @featuredPage.PageTypeBadge.Label
                                                        </span>
                                                    }
                                                </div>
                                                <h4 class="mt-3 text-lg font-semibold text-white transition-colors docs-token-group-hover-text-accent-soft">@featuredPage.Title</h4>
                                                @if (!string.IsNullOrWhiteSpace(featuredPage.SupportingText))
                                                {
                                                    <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-300">@featuredPage.SupportingText</p>
                                                }
                                            </div>
                                            <span class="inline-flex items-center text-sm font-semibold docs-token-text-info-muted transition-colors docs-token-group-hover-text-accent-soft">
                                                <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                                                    <circle cx="10" cy="10" r="7"></circle>
                                                    <path d="M8.5 6.75L11.75 10 8.5 13.25"></path>
                                                </svg>
                                            </span>
                                        </div>
                                    </a>
                                </li>
                            }
                        </ul>
                    </section>
                }
            </div>
        }
    </section>

    @if (Model.SecondarySections.Count > 0)
    {
        <div class="mt-10 space-y-6">
            @foreach (var secondarySection in Model.SecondarySections)
            {
                <section class="border-b border-slate-900/80 pb-6 last:border-b-0 last:pb-0">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                        <div class="min-w-0 flex-1">
                            <a href="@Url.PathBaseAware(secondarySection.Href)"
                               class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400 transition-colors docs-token-hover-text-accent">
                                @secondarySection.Label
                            </a>
                            <p class="mt-3 max-w-3xl text-sm leading-6 text-slate-300">@secondarySection.Purpose</p>
                        </div>
                    </div>

                    @if (secondarySection.KeyRoutes.Count > 0)
                    {
                        <ul class="mt-4 space-y-3">
                            @foreach (var route in secondarySection.KeyRoutes)
                            {
                                <li>
                                    <a href="@Url.PathBaseAware(route.Href)"
                                       data-turbo-frame="doc-content"
                                       data-turbo-action="advance"
                                       class="group flex flex-col gap-2 rounded-lg border docs-token-border-muted docs-token-bg-panel-faint px-4 py-3 transition-colors docs-token-hover-border-accent docs-token-hover-bg-panel sm:flex-row sm:items-start sm:justify-between">
                                        <div class="min-w-0 flex-1">
                                            @if (!string.IsNullOrWhiteSpace(route.Eyebrow))
                                            {
                                                <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500">@route.Eyebrow</p>
                                            }
                                            <div class="mt-1 flex flex-wrap items-center gap-2">
                                                <span class="text-base font-semibold text-white transition-colors docs-token-group-hover-text-accent-soft">@route.Title</span>
                                                @if (route.PageTypeBadge is not null)
                                                {
                                                    <span class="docs-page-badge docs-page-badge--@route.PageTypeBadge.Variant">
                                                        @route.PageTypeBadge.Label
                                                    </span>
                                                }
                                            </div>
                                            @if (!string.IsNullOrWhiteSpace(route.Summary))
                                            {
                                                <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-400">@route.Summary</p>
                                            }
                                        </div>
                                        <span class="inline-flex items-center text-sm font-semibold docs-token-text-info-muted transition-colors docs-token-group-hover-text-accent-soft">
                                            <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
                                                <circle cx="10" cy="10" r="7"></circle>
                                                <path d="M8.5 6.75L11.75 10 8.5 13.25"></path>
                                            </svg>
                                        </span>
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                </section>
            }
        </div>
    }
</div>
