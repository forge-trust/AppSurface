@model ForgeTrust.AppSurface.Docs.Models.RazorDocsHarvestHealthResponse
@{
    ViewData["Title"] = "Harvest Health";
    var statusClass = Model.Verification.Ok
        ? "border-emerald-400/35 bg-emerald-950/35 text-emerald-100"
        : "border-rose-400/40 bg-rose-950/40 text-rose-100";
    var statusTextClass = Model.Verification.Ok ? "text-emerald-300" : "text-rose-300";
}

<div class="mx-auto max-w-6xl px-4 py-6 sm:px-6 sm:py-8 lg:px-8">
    <header class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">RazorDocs</p>
        <div class="mt-3 flex flex-wrap items-center gap-3">
            <h1 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Harvest Health</h1>
            <span class="rounded-full border px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] @statusClass">
                @Model.Status
            </span>
        </div>
        <p class="mt-4 text-base leading-7 text-slate-300">
            Snapshot generated @Model.GeneratedUtc.ToString("u"). Verification is
            <span class="font-semibold @statusTextClass">@(Model.Verification.Ok ? "passing" : "failing")</span>.
        </p>
    </header>

    <section class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-label="Harvest summary">
        <div class="rounded-xl border border-slate-800 bg-slate-950/45 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Docs</p>
            <p class="mt-2 text-3xl font-semibold text-white">@Model.TotalDocs</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-950/45 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Harvesters</p>
            <p class="mt-2 text-3xl font-semibold text-white">@Model.TotalHarvesters</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-950/45 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Successful</p>
            <p class="mt-2 text-3xl font-semibold text-emerald-200">@Model.SuccessfulHarvesters</p>
        </div>
        <div class="rounded-xl border border-slate-800 bg-slate-950/45 p-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Failed</p>
            <p class="mt-2 text-3xl font-semibold @(Model.FailedHarvesters == 0 ? "text-slate-200" : "text-rose-200")">@Model.FailedHarvesters</p>
        </div>
    </section>

    <section class="mt-8" aria-labelledby="harvesters-heading">
        <h2 id="harvesters-heading" class="text-xl font-semibold text-white">Harvesters</h2>
        <div class="mt-4 overflow-hidden rounded-xl border border-slate-800">
            <table class="min-w-full divide-y divide-slate-800 text-left text-sm">
                <thead class="bg-slate-950/70 text-xs uppercase tracking-[0.16em] text-slate-500">
                    <tr>
                        <th scope="col" class="px-4 py-3 font-semibold">Harvester</th>
                        <th scope="col" class="px-4 py-3 font-semibold">Status</th>
                        <th scope="col" class="px-4 py-3 font-semibold">Docs</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800 bg-slate-950/30">
                    @foreach (var harvester in Model.Harvesters)
                    {
                        <tr>
                            <td class="px-4 py-3 text-slate-200">@harvester.HarvesterType</td>
                            <td class="px-4 py-3 text-slate-300">@harvester.Status</td>
                            <td class="px-4 py-3 text-slate-300">@harvester.DocCount</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    @if (Model.Diagnostics.Count > 0)
    {
        <section class="mt-8" aria-labelledby="diagnostics-heading">
            <h2 id="diagnostics-heading" class="text-xl font-semibold text-white">Diagnostics</h2>
            <ul class="mt-4 space-y-3">
                @foreach (var diagnostic in Model.Diagnostics)
                {
                    <li class="rounded-xl border border-slate-800 bg-slate-950/45 p-4">
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="text-sm font-semibold text-white">@diagnostic.Code</span>
                            <span class="rounded-full border border-slate-700 px-2 py-0.5 text-[0.7rem] font-semibold uppercase tracking-[0.12em] text-slate-400">@diagnostic.Severity</span>
                            @if (!string.IsNullOrWhiteSpace(diagnostic.HarvesterType))
                            {
                                <span class="text-xs text-slate-500">@diagnostic.HarvesterType</span>
                            }
                        </div>
                        <p class="mt-3 text-sm leading-6 text-slate-300">@diagnostic.Problem</p>
                        @if (!string.IsNullOrWhiteSpace(diagnostic.Fix))
                        {
                            <p class="mt-2 text-sm leading-6 text-slate-400">@diagnostic.Fix</p>
                        }
                    </li>
                }
            </ul>
        </section>
    }
</div>
