@model ForgeTrust.AppSurface.Docs.Models.DocDetailsViewModel
@inject ForgeTrust.AppSurface.Docs.Services.DocsUrlBuilder DocsUrlBuilder
@{
    ViewData["Title"] = Model.Title;
    var docsOutlineClientUrl = $"{Url.PathBaseAware(DocsUrlBuilder.BuildAssetUrl("outline-client.js"))}?v=rolling-context";
    var trust = Model.Document.Metadata?.Trust;
    var trustStatus = string.IsNullOrWhiteSpace(trust?.Status) ? null : trust!.Status!.Trim();
    var trustSummary = string.IsNullOrWhiteSpace(trust?.Summary) ? null : trust!.Summary!.Trim();
    var trustFreshness = string.IsNullOrWhiteSpace(trust?.Freshness) ? null : trust!.Freshness!.Trim();
    var trustChangeScope = string.IsNullOrWhiteSpace(trust?.ChangeScope) ? null : trust!.ChangeScope!.Trim();
    var trustArchive = string.IsNullOrWhiteSpace(trust?.Archive) ? null : trust!.Archive!.Trim();
    var trustSources = trust?.Sources?
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Select(value => value.Trim())
        .ToList()
        ?? [];
    var trustMigration = trust?.Migration;
    var trustMigrationHref = string.IsNullOrWhiteSpace(trustMigration?.Href) ? null : trustMigration!.Href!.Trim();
    var trustMigrationLabel = string.IsNullOrWhiteSpace(trustMigration?.Label)
        ? "Migration guidance"
        : trustMigration!.Label!.Trim();
    var showTrustBar = trustStatus is not null
                       || trustSummary is not null
                       || trustFreshness is not null
                       || trustChangeScope is not null
                       || trustArchive is not null
                       || trustMigrationHref is not null
                       || trustSources.Count > 0;
    var provenance = Model.ContributorProvenance;
    var sourceHref = string.IsNullOrWhiteSpace(provenance?.SourceHref) ? null : provenance!.SourceHref!.Trim();
    var editHref = string.IsNullOrWhiteSpace(provenance?.EditHref) ? null : provenance!.EditHref!.Trim();
    var provenanceLabel = string.IsNullOrWhiteSpace(provenance?.Label) ? "Source of truth" : provenance!.Label.Trim();
    var lastUpdatedUtc = provenance?.LastUpdatedUtc?.ToUniversalTime();
    var showContributorProvenance = sourceHref is not null || editHref is not null || lastUpdatedUtc is not null;
    var outlineItems = Model.Outline
        .Where(item => item is not null && !string.IsNullOrWhiteSpace(item.Id) && !string.IsNullOrWhiteSpace(item.Title))
        .Select(item => new
        {
            Id = item.Id.Trim(),
            Title = item.Title.Trim(),
            item.Level
        })
        .ToList();
    var hasOutline = outlineItems.Count > 0;
    var documentContent = ResolveGeneratedContentHrefs(Model.Document.Content);
    var visibleDocumentContent = ForgeTrust.AppSurface.Docs.Services.RazorDocsHeadingSuppressor.SuppressLeadingMarkdownH1(
        documentContent,
        shellOwnsH1: !Model.IsCSharpApiDoc);
}
@functions {
    private static readonly System.Text.RegularExpressions.Regex RootedSymbolSourceLinkRegex = new(
        """<a\b(?:(?:[^>]*\bhref\s*=\s*"(?<hrefBefore>/[^"]*)"[^>]*\bclass\s*=\s*"(?:doc-symbol-source-link(?:\s[^"]*)?|[^"]*\sdoc-symbol-source-link(?:\s[^"]*)?)")|(?:[^>]*\bclass\s*=\s*"(?:doc-symbol-source-link(?:\s[^"]*)?|[^"]*\sdoc-symbol-source-link(?:\s[^"]*)?)"[^>]*\bhref\s*=\s*"(?<hrefAfter>/[^"]*)"))[^>]*>""",
        System.Text.RegularExpressions.RegexOptions.IgnoreCase
        | System.Text.RegularExpressions.RegexOptions.NonBacktracking);

    private string ResolveGeneratedContentHrefs(string content)
    {
        if (string.IsNullOrEmpty(content)
            || !Context.Request.PathBase.HasValue
            || content.IndexOf("doc-symbol-source-link", StringComparison.Ordinal) < 0
            || !RootedSymbolSourceLinkRegex.IsMatch(content))
        {
            return content;
        }

        return RootedSymbolSourceLinkRegex.Replace(
            content,
            match =>
            {
                var encodedHref = match.Groups["hrefBefore"].Success
                    ? match.Groups["hrefBefore"].Value
                    : match.Groups["hrefAfter"].Value;
                var href = System.Net.WebUtility.HtmlDecode(encodedHref);
                if (href.StartsWith("//", StringComparison.Ordinal))
                {
                    return match.Value;
                }

                var resolvedHref = Url.Content($"~{href}");
                return match.Value.Replace(encodedHref, System.Net.WebUtility.HtmlEncode(resolvedHref), StringComparison.Ordinal);
            });
    }
}

<header class="@(Model.IsCSharpApiDoc ? "mb-5" : "mb-8")">
    @if (!string.IsNullOrWhiteSpace(Model.PublicSectionLabel) && !string.IsNullOrWhiteSpace(Model.PublicSectionHref))
    {
        <div class="mb-4 md:hidden">
            <a href="@Url.PathBaseAware(Model.PublicSectionHref)"
               data-turbo-frame="doc-content"
               data-turbo-action="advance"
               class="inline-flex items-center gap-2 rounded-full border border-[#314461] bg-[#0d182a]/80 px-3 py-1.5 text-xs font-semibold uppercase tracking-[0.16em] text-slate-200 transition-colors hover:border-[#14b8a6]/45 hover:text-[#99f6e4]">
                <span class="text-slate-500">Section</span>
                <span>@Model.PublicSectionLabel</span>
            </a>
        </div>
    }

    @if (Model.Breadcrumbs.Count > 0)
    {
        <nav aria-label="Breadcrumb" class="mb-3 flex flex-wrap items-center gap-1 text-xs font-mono text-slate-500">
            @for (var i = 0; i < Model.Breadcrumbs.Count; i++)
            {
                var crumb = Model.Breadcrumbs[i];
                var isLast = i == Model.Breadcrumbs.Count - 1;

                if (isLast || string.IsNullOrWhiteSpace(crumb.Href))
                {
                    <span class="inline-flex max-w-full overflow-x-auto whitespace-nowrap rounded border border-slate-700 bg-slate-800 px-2 py-0.5">@crumb.Label</span>
                }
                else
                {
                    <a href="@Url.PathBaseAware(crumb.Href)"
                       data-turbo-frame="doc-content"
                       data-turbo-action="advance"
                       class="px-1 text-slate-400 transition-colors hover:text-[#14b8a6]">
                        @crumb.Label
                    </a>
                }

                if (!isLast)
                {
                    <span class="text-slate-600">/</span>
                }
            }
        </nav>
    }

    @if (Model.PageTypeBadge is not null || Model.Component is not null || Model.Audience is not null)
    {
        <div class="docs-page-meta">
            @if (Model.PageTypeBadge is not null)
            {
                <span class="docs-page-badge docs-page-badge--@Model.PageTypeBadge.Variant">@Model.PageTypeBadge.Label</span>
            }
            @if (Model.Component is not null)
            {
                <span class="docs-metadata-chip">Component: @Model.Component</span>
            }
            @if (Model.Audience is not null)
            {
                <span class="docs-metadata-chip">Audience: @Model.Audience</span>
            }
        </div>
    }

    @if (!Model.IsCSharpApiDoc)
    {
        <h1 class="max-w-full break-words text-3xl font-bold leading-tight tracking-tight text-white">@Model.Title</h1>
        @if (Model.ShowSummary && !string.IsNullOrWhiteSpace(Model.Summary))
        {
            <p class="mt-3 max-w-3xl text-base text-slate-400">@Model.Summary</p>
        }
    }

    @if (showContributorProvenance)
    {
        <section class="docs-provenance-strip" aria-label="@provenanceLabel">
            <p class="docs-provenance-label">@provenanceLabel</p>
            <div class="docs-provenance-items">
                @if (sourceHref is not null)
                {
                    <a href="@Url.PathBaseAware(sourceHref)"
                       class="docs-provenance-link docs-provenance-link--primary"
                       @if (Model.ContributorSourceUsesTurbo)
                       {
                           <text>data-turbo-frame="doc-content" data-turbo-action="advance"</text>
                       }>View source</a>
                }
                @if (editHref is not null)
                {
                    <a href="@Url.PathBaseAware(editHref)"
                       class="docs-provenance-link docs-provenance-link--secondary"
                       @if (Model.ContributorEditUsesTurbo)
                       {
                           <text>data-turbo-frame="doc-content" data-turbo-action="advance"</text>
                       }>
                        <span class="docs-provenance-pencil" aria-hidden="true">✎</span>
                        <span>Edit this page</span>
                    </a>
                }
                @if (lastUpdatedUtc is not null)
                {
                    <p class="docs-provenance-item">
                        <span class="docs-provenance-key">Last updated</span>
                        <time class="docs-provenance-time"
                              rw-type="local"
                              datetime="@lastUpdatedUtc.Value"
                              rw-display="relative"></time>
                    </p>
                }
            </div>
        </section>
    }

    @if (showTrustBar)
    {
        <section class="docs-trust-bar" aria-label="Page trust and provenance">
            @if (trustStatus is not null || trustSummary is not null)
            {
                <article class="docs-trust-bar-section">
                    <p class="docs-trust-bar-label">Status</p>
                    @if (trustStatus is not null)
                    {
                        <p class="docs-trust-bar-status-row">
                            <span class="docs-trust-bar-status-badge">@trustStatus</span>
                        </p>
                    }
                    @if (trustSummary is not null)
                    {
                        <p class="docs-trust-bar-value">@trustSummary</p>
                    }
                </article>
            }
            @if (trustChangeScope is not null || trustFreshness is not null || trustMigrationHref is not null)
            {
                <article class="docs-trust-bar-section">
                    <p class="docs-trust-bar-label">Safe To Consume</p>
                    @if (trustChangeScope is not null)
                    {
                        <p class="docs-trust-bar-value"><span class="docs-trust-bar-key">Scope:</span> @trustChangeScope</p>
                    }
                    @if (trustFreshness is not null)
                    {
                        <p class="docs-trust-bar-value"><span class="docs-trust-bar-key">Freshness:</span> @trustFreshness</p>
                    }
                    @if (trustMigrationHref is not null)
                    {
                        <p class="docs-trust-bar-value">
                            <span class="docs-trust-bar-key">Migration:</span>
                            <a href="@Url.PathBaseAware(trustMigrationHref)"
                               class="docs-trust-bar-link"
                               @if (Model.TrustMigrationUsesTurbo)
                               {
                                   <text>data-turbo-frame="doc-content" data-turbo-action="advance"</text>
                               }>@trustMigrationLabel</a>
                        </p>
                    }
                </article>
            }
            @if (trustArchive is not null || trustSources.Count > 0)
            {
                <article class="docs-trust-bar-section">
                    <p class="docs-trust-bar-label">Record</p>
                    @if (trustArchive is not null)
                    {
                        <p class="docs-trust-bar-value">@trustArchive</p>
                    }
                    @if (trustSources.Count > 0)
                    {
                        <ul class="docs-trust-bar-list">
                            @foreach (var source in trustSources)
                            {
                                <li>@source</li>
                            }
                        </ul>
                    }
                </article>
            }
        </section>
    }
</header>

<div class="docs-detail-layout @(hasOutline ? "docs-detail-layout--with-outline" : null)">
    <div class="docs-detail-primary">
        @if (Model.IsSectionLanding)
        {
            <section class="mb-10 rounded-lg border border-[#1b2a43] bg-[#050b17]/35 p-5 sm:p-6">
                <div class="flex flex-col gap-3 border-b border-[#1b2a43] pb-4 sm:flex-row sm:items-end sm:justify-between">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.16em] text-[#14b8a6]">Section landing</p>
                        <h2 class="mt-2 text-xl font-semibold text-white">Use this section as the entry point.</h2>
                        @if (!string.IsNullOrWhiteSpace(Model.PublicSectionPurpose))
                        {
                            <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-300">@Model.PublicSectionPurpose</p>
                        }
                    </div>
                    @if (!string.IsNullOrWhiteSpace(Model.PublicSectionHref))
                    {
                        <a href="@Url.PathBaseAware(Model.PublicSectionHref)"
                           data-turbo-frame="doc-content"
                           data-turbo-action="advance"
                           class="inline-flex items-center gap-2 self-start rounded-full border border-[#314461] bg-[#0d182a]/70 px-4 py-2 text-sm font-semibold text-slate-200 transition-colors hover:border-[#14b8a6]/45 hover:text-[#99f6e4]">
                            Section route
                        </a>
                    }
                </div>

                @if (Model.HasFeaturedPages)
                {
                    <div class="mt-5 space-y-5">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Next steps</p>
                        @foreach (var featuredGroup in Model.FeaturedPageGroups.Where(group => group.Pages.Count > 0))
                        {
                            <section>
                                <h3 class="text-sm font-semibold text-white">@featuredGroup.Label</h3>
                                @if (!string.IsNullOrWhiteSpace(featuredGroup.Summary))
                                {
                                    <p class="mt-2 max-w-2xl text-sm leading-6 text-slate-400">@featuredGroup.Summary</p>
                                }
                                <ul class="mt-3 space-y-3">
                                    @foreach (var featuredPage in featuredGroup.Pages)
                                    {
                                        <li>
                                            <a href="@Url.PathBaseAware(featuredPage.Href)"
                                               data-turbo-frame="doc-content"
                                               data-turbo-action="advance"
                                               class="group block rounded-lg border border-[#1b2a43] bg-[#050b17]/60 px-4 py-3 transition-colors hover:border-[#14b8a6]/35 hover:bg-[#08101e]">
                                                <div class="flex flex-wrap items-center gap-2">
                                                    @if (!string.IsNullOrWhiteSpace(featuredPage.Question))
                                                    {
                                                        <span class="text-[10px] font-semibold uppercase tracking-[0.16em] text-[#14b8a6]">@featuredPage.Question</span>
                                                    }
                                                    @if (featuredPage.PageTypeBadge is not null)
                                                    {
                                                        <span class="docs-page-badge docs-page-badge--@featuredPage.PageTypeBadge.Variant">@featuredPage.PageTypeBadge.Label</span>
                                                    }
                                                </div>
                                                <h4 class="mt-2 text-base font-semibold text-white transition-colors group-hover:text-[#ccfbf1]">@featuredPage.Title</h4>
                                                @if (!string.IsNullOrWhiteSpace(featuredPage.SupportingText))
                                                {
                                                    <p class="mt-2 text-sm leading-6 text-slate-400">@featuredPage.SupportingText</p>
                                                }
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </section>
                        }
                    </div>
                }

                @if (Model.SectionGroups.Count > 0)
                {
                    <div class="mt-6">
                        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">In this section</p>
                        <div class="mt-3 space-y-5">
                            @foreach (var sectionGroup in Model.SectionGroups)
                            {
                                <section>
                                    @if (!string.IsNullOrWhiteSpace(sectionGroup.Title))
                                    {
                                        <h3 class="mb-2 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-500">@sectionGroup.Title</h3>
                                    }
                                    <ul class="space-y-3">
                                        @foreach (var link in sectionGroup.Links)
                                        {
                                            <li>
                                                <a href="@Url.PathBaseAware(link.Href)"
                                                   data-turbo-frame="doc-content"
                                                   data-turbo-action="advance"
                                                   class="group block rounded-lg border border-[#1b2a43] bg-[#050b17]/50 px-4 py-3 transition-colors hover:border-[#14b8a6]/35 hover:bg-[#08101e]">
                                                    <div class="flex flex-wrap items-center gap-2">
                                                        <span class="text-sm font-semibold text-white transition-colors group-hover:text-[#ccfbf1]">@link.Title</span>
                                                        @if (link.PageTypeBadge is not null)
                                                        {
                                                            <span class="docs-page-badge docs-page-badge--@link.PageTypeBadge.Variant">@link.PageTypeBadge.Label</span>
                                                        }
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(link.Summary))
                                                    {
                                                        <p class="mt-2 text-sm leading-6 text-slate-400">@link.Summary</p>
                                                    }
                                                </a>

                                                @await Html.PartialAsync("_DocSectionCardChildren", link.Children)
                                            </li>
                                        }
                                    </ul>
                                </section>
                            }
                        </div>
                    </div>
                }
            </section>
        }

        <div class="docs-content @(Model.IsApiSurfaceDoc ? "docs-content--api" : "docs-content--markdown")">
            @* Safe: Content is sanitized by DocAggregator before caching. *@
            @Html.Raw(visibleDocumentContent)
        </div>

        @if (Model.HasWayfinding)
        {
            <section id="docs-page-wayfinding" class="mt-10 space-y-6 border-t border-[#1b2a43] pt-8">
                @if (Model.PreviousPage is not null || Model.NextPage is not null)
                {
                    <div class="space-y-3">
                        <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Continue the proof path</div>
                        <div class="grid gap-3 md:grid-cols-2">
                            @if (Model.PreviousPage is not null)
                            {
                                <a href="@Url.PathBaseAware(Model.PreviousPage.Href)"
                                   data-doc-wayfinding="previous"
                                   data-turbo-frame="doc-content"
                                   data-turbo-action="advance"
                                   class="block rounded-lg border border-[#1b2a43] bg-[#0d182a]/60 px-4 py-4 transition-colors hover:border-[#14b8a6]/45 hover:bg-[#0d182a]">
                                    <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Previous</div>
                                    <div class="mt-2 text-base font-semibold text-white">@Model.PreviousPage.Title</div>
                                    @if (Model.PreviousPage.PageTypeBadge is not null)
                                    {
                                        <span class="docs-page-badge docs-page-badge--@Model.PreviousPage.PageTypeBadge.Variant mt-3 inline-flex">@Model.PreviousPage.PageTypeBadge.Label</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(Model.PreviousPage.Summary))
                                    {
                                        <p class="mt-3 text-sm text-slate-400">@Model.PreviousPage.Summary</p>
                                    }
                                </a>
                            }
                            @if (Model.NextPage is not null)
                            {
                                <a href="@Url.PathBaseAware(Model.NextPage.Href)"
                                   data-doc-wayfinding="next"
                                   data-turbo-frame="doc-content"
                                   data-turbo-action="advance"
                                   class="block rounded-lg border border-[#1b2a43] bg-[#0d182a]/60 px-4 py-4 transition-colors hover:border-[#14b8a6]/45 hover:bg-[#0d182a]">
                                    <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Next</div>
                                    <div class="mt-2 text-base font-semibold text-white">@Model.NextPage.Title</div>
                                    @if (Model.NextPage.PageTypeBadge is not null)
                                    {
                                        <span class="docs-page-badge docs-page-badge--@Model.NextPage.PageTypeBadge.Variant mt-3 inline-flex">@Model.NextPage.PageTypeBadge.Label</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(Model.NextPage.Summary))
                                    {
                                        <p class="mt-3 text-sm text-slate-400">@Model.NextPage.Summary</p>
                                    }
                                </a>
                            }
                        </div>
                    </div>
                }

                @if (Model.RelatedPages.Count > 0)
                {
                    <div class="space-y-3">
                        <div class="text-[11px] font-semibold uppercase tracking-[0.18em] text-slate-500">Related pages</div>
                        <div class="grid gap-3 md:grid-cols-2">
                            @foreach (var relatedPage in Model.RelatedPages)
                            {
                                <a href="@Url.PathBaseAware(relatedPage.Href)"
                                   data-doc-related-link="true"
                                   data-turbo-frame="doc-content"
                                   data-turbo-action="advance"
                                   class="block rounded-lg border border-[#1b2a43] bg-[#0d182a]/40 px-4 py-4 transition-colors hover:border-[#14b8a6]/45 hover:bg-[#0d182a]">
                                    <div class="text-base font-semibold text-white">@relatedPage.Title</div>
                                    @if (relatedPage.PageTypeBadge is not null)
                                    {
                                        <span class="docs-page-badge docs-page-badge--@relatedPage.PageTypeBadge.Variant mt-3 inline-flex">@relatedPage.PageTypeBadge.Label</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(relatedPage.Summary))
                                    {
                                        <p class="mt-3 text-sm text-slate-400">@relatedPage.Summary</p>
                                    }
                                </a>
                            }
                        </div>
                    </div>
                }
            </section>
        }
    </div>

    @if (hasOutline)
    {
        <aside id="docs-page-outline"
               class="docs-outline-shell"
               data-doc-outline="true"
               data-outline-expanded="true">
            <button class="docs-outline-toggle"
                    type="button"
                    aria-label="On this page: @Model.Title"
                    aria-expanded="true"
                    aria-controls="docs-page-outline-panel"
                    data-doc-outline-toggle="true">
                <span class="docs-outline-toggle-label">@Model.Title</span>
                <span class="docs-outline-toggle-context"
                      data-doc-outline-context
                      aria-hidden="true">
                    <span class="docs-outline-context-row docs-outline-context-row--previous"
                          data-doc-outline-previous
                          hidden>
                        <span class="docs-outline-context-kicker">Prev</span>
                        <span data-doc-outline-context-title></span>
                    </span>
                    <span class="docs-outline-context-row docs-outline-context-row--current"
                          data-doc-outline-current></span>
                    <span class="docs-outline-context-row docs-outline-context-row--next"
                          data-doc-outline-next
                          hidden>
                        <span class="docs-outline-context-kicker">Next</span>
                        <span data-doc-outline-context-title></span>
                    </span>
                </span>
            </button>
            <nav id="docs-page-outline-panel"
                 class="docs-outline-panel"
                 aria-label="On this page">
                <div class="docs-outline-label">On this page</div>
                <span class="docs-section-copy-status" data-doc-section-copy-status aria-live="polite"></span>
                <ol class="docs-outline-list">
                    @foreach (var item in outlineItems)
                    {
                        var linkClass = item.Level > 2
                            ? "docs-outline-link docs-outline-link--level-3"
                            : "docs-outline-link";
                        <li class="docs-outline-item">
                            <a href="#@item.Id"
                               data-doc-outline-link="true"
                               class="@linkClass">
                                @item.Title
                            </a>
                            <button type="button"
                                    class="docs-section-copy docs-outline-copy"
                                    data-doc-section-copy="@item.Id"
                                    data-doc-section-copy-title="@item.Title"
                                    aria-label="Copy link to @item.Title">
                                <svg class="docs-section-copy-icon"
                                     aria-hidden="true"
                                     focusable="false"
                                     viewBox="0 0 24 24">
                                    <rect x="9" y="9" width="11" height="11" rx="2" ry="2"></rect>
                                    <path d="M5 15V6a2 2 0 0 1 2-2h9"></path>
                                </svg>
                            </button>
                        </li>
                    }
                </ol>
            </nav>
        </aside>
    }
</div>

@if (hasOutline)
{
    <script src="@docsOutlineClientUrl" defer data-doc-outline-client="true"></script>
}
