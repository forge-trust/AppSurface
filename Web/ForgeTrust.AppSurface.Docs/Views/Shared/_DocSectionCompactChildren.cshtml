@model IReadOnlyList<ForgeTrust.AppSurface.Docs.Models.DocSectionLinkViewModel>
@{
    var depth = ViewData["Depth"] is int currentDepth ? currentDepth : 0;
    var childViewData = new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
    {
        ["Depth"] = depth + 1
    };
}

@if (Model.Count > 0)
{
    <ul class="ml-4 mt-1 space-y-0.5 border-l border-slate-800">
        @foreach (var child in Model)
        {
            <li>
                <a href="@Url.PathBaseAware(child.Href)"
                   data-doc-anchor-link="true"
                   data-turbo-frame="doc-content"
                   data-turbo-action="advance"
                   class="block px-4 py-1 text-xs transition-colors @(child.IsCurrent ? "text-cyan-300" : "text-slate-500 hover:text-cyan-300")"
                   aria-current="@(child.IsCurrent ? "page" : null)">
                    @child.Title
                </a>

                @await Html.PartialAsync("_DocSectionCompactChildren", child.Children, childViewData)
            </li>
        }
    </ul>
}
