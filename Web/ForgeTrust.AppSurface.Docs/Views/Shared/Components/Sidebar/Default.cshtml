@model ForgeTrust.AppSurface.Docs.Models.DocSidebarViewModel
@if (Model.HarvestHealth is not null)
{
    var statusClass = Model.HarvestHealth.Ok
        ? "border-emerald-500/30 bg-emerald-950/25 text-emerald-200"
        : "border-rose-500/35 bg-rose-950/30 text-rose-200";
    var dotClass = Model.HarvestHealth.Ok ? "bg-emerald-300" : "bg-rose-300";

    @if (!string.IsNullOrWhiteSpace(Model.HarvestHealth.Href))
    {
        <a href="@Url.PathBaseAware(Model.HarvestHealth.Href)"
           class="mb-3 flex items-center justify-between gap-3 rounded-lg border px-3 py-2 text-xs font-semibold no-underline transition-colors hover:border-[#14b8a6]/45 @statusClass">
            <span class="inline-flex min-w-0 items-center gap-2">
                <span class="h-2 w-2 flex-none rounded-full @dotClass" aria-hidden="true"></span>
                <span class="truncate">Harvest @Model.HarvestHealth.Status</span>
            </span>
            <span class="flex-none uppercase tracking-[0.12em]">Health</span>
        </a>
    }
    else
    {
        <div class="mb-3 flex items-center justify-between gap-3 rounded-lg border px-3 py-2 text-xs font-semibold @statusClass"
             aria-label="Harvest @Model.HarvestHealth.Status">
            <span class="inline-flex min-w-0 items-center gap-2">
                <span class="h-2 w-2 flex-none rounded-full @dotClass" aria-hidden="true"></span>
                <span class="truncate">Harvest @Model.HarvestHealth.Status</span>
            </span>
            <span class="flex-none uppercase tracking-[0.12em]">Health</span>
        </div>
    }
}
@foreach (var sidebarSection in Model.Sections)
{
    <details class="group border-b border-[#0d182a]/80 py-2 last:border-b-0" @(sidebarSection.IsExpanded ? "open" : null)>
        <summary class="list-none cursor-pointer">
            <div class="flex items-center justify-between gap-3 rounded-lg px-2 py-2 transition-colors hover:bg-[#0d182a]/70">
                <a href="@Url.PathBaseAware(sidebarSection.Href)"
                   class="text-xs font-semibold uppercase tracking-[0.16em] @(sidebarSection.IsActive ? "text-[#14b8a6]" : "text-slate-400 hover:text-[#14b8a6]")"
                   aria-current="@(sidebarSection.IsActive ? "location" : null)">
                    @sidebarSection.Label
                </a>
                <span class="text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-600 transition-transform group-open:rotate-90" aria-hidden="true">›</span>
            </div>
        </summary>

        <div class="mt-1 space-y-3 px-2 pb-2">
            @foreach (var sectionGroup in sidebarSection.Groups)
            {
                <div class="space-y-1">
                    @if (!string.IsNullOrWhiteSpace(sectionGroup.Title))
                    {
                        <div class="px-2 pb-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-600">@sectionGroup.Title</div>
                    }

                    <ul class="space-y-1">
                        @foreach (var link in sectionGroup.Links)
                        {
                            <li>
                                <a href="@Url.PathBaseAware(link.Href)"
                                   data-turbo-frame="doc-content"
                                   data-turbo-action="advance"
                                   class="block rounded-md px-2 py-1.5 text-sm font-medium transition-colors @(link.IsCurrent ? "bg-[#0d182a] text-[#bfdbfe]" : "text-slate-400 hover:bg-[#0d182a] hover:text-[#14b8a6]")"
                                   aria-current="@(link.IsCurrent ? "page" : null)">
                                    @link.Title
                                </a>

                                @await Html.PartialAsync("_DocSectionCompactChildren", link.Children)
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </details>
}
