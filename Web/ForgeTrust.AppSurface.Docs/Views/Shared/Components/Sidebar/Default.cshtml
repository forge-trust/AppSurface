@model ForgeTrust.AppSurface.Docs.Models.DocSidebarViewModel
@if (Model.Diagnostics is not null)
{
    var diagnosticsStatusClass = Model.Diagnostics.Status?.Ok == true
        ? "border-emerald-500/30 bg-emerald-950/25 text-emerald-200"
        : "border-rose-500/35 bg-rose-950/30 text-rose-200";
    var diagnosticsDotClass = Model.Diagnostics.Status?.Ok == true ? "bg-emerald-300" : "bg-rose-300";

    <details class="group mb-3 rounded-lg border border-[#1b2a43] bg-[#07111f]/70 text-xs" data-docs-diagnostics-chrome="true">
        <summary class="list-none cursor-pointer">
            <div class="flex items-center justify-between gap-3 rounded-lg px-3 py-2 transition-colors hover:bg-[#0d182a]/70">
                <span class="min-w-0 truncate font-semibold uppercase tracking-[0.16em] text-slate-300">@Model.Diagnostics.Label</span>
                <span class="inline-flex flex-none items-center gap-2">
                    @if (Model.Diagnostics.Status is not null)
                    {
                        <span class="inline-flex max-w-[8rem] items-center gap-1.5 rounded-full border px-2 py-0.5 font-semibold @diagnosticsStatusClass">
                            <span class="h-1.5 w-1.5 flex-none rounded-full @diagnosticsDotClass" aria-hidden="true"></span>
                            <span class="truncate">@Model.Diagnostics.Status.Label</span>
                        </span>
                    }
                    <span class="font-semibold uppercase tracking-[0.2em] text-slate-600 transition-transform group-open:rotate-90" aria-hidden="true">&rsaquo;</span>
                </span>
            </div>
        </summary>

        @if (Model.Diagnostics.Tools.Count > 0)
        {
            <ul class="space-y-1 px-2 pb-2">
                @foreach (var diagnosticsTool in Model.Diagnostics.Tools)
                {
                    <li class="flex items-center justify-between gap-2 rounded-md px-2 py-1.5">
                        <span class="min-w-0">
                            @if (!string.IsNullOrWhiteSpace(diagnosticsTool.Href))
                            {
                                <a href="@Url.PathBaseAware(diagnosticsTool.Href)"
                                   class="block truncate text-sm font-medium text-slate-300 no-underline transition-colors hover:text-[#14b8a6]">
                                    @diagnosticsTool.Label
                                </a>
                            }
                            else
                            {
                                <span class="block truncate text-sm font-medium text-slate-300">@diagnosticsTool.Label</span>
                            }

                            @if (!string.IsNullOrWhiteSpace(diagnosticsTool.Summary))
                            {
                                <span class="block truncate text-[11px] font-medium text-slate-500">@diagnosticsTool.Summary</span>
                            }
                        </span>

                        @if (diagnosticsTool.JsonAction is not null)
                        {
                            <a href="@Url.PathBaseAware(diagnosticsTool.JsonAction.Href)"
                               class="flex-none rounded border border-[#1b2a43] px-1.5 py-0.5 text-[10px] font-semibold uppercase tracking-[0.12em] text-slate-400 no-underline transition-colors hover:border-[#14b8a6]/45 hover:text-[#14b8a6]">
                                @diagnosticsTool.JsonAction.Label
                            </a>
                        }
                    </li>
                }
            </ul>
        }
    </details>
}
@foreach (var sidebarSection in Model.Sections)
{
    <details class="group border-b border-[#0d182a]/80 py-2 last:border-b-0" @(sidebarSection.IsExpanded ? "open" : null)>
        <summary class="list-none cursor-pointer">
            <div class="flex items-center justify-between gap-3 rounded-lg px-2 py-2 transition-colors hover:bg-[#0d182a]/70">
                <a href="@Url.PathBaseAware(sidebarSection.Href)"
                   class="text-xs font-semibold uppercase tracking-[0.16em] @(sidebarSection.IsActive ? "text-[#14b8a6]" : "text-slate-400 hover:text-[#14b8a6]")"
                   aria-current="@(sidebarSection.IsActive ? "location" : null)">
                    @sidebarSection.Label
                </a>
                <span class="text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-600 transition-transform group-open:rotate-90" aria-hidden="true">›</span>
            </div>
        </summary>

        <div class="mt-1 space-y-3 px-2 pb-2">
            @foreach (var sectionGroup in sidebarSection.Groups)
            {
                <div class="space-y-1">
                    @if (!string.IsNullOrWhiteSpace(sectionGroup.Title))
                    {
                        <div class="px-2 pb-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-600">@sectionGroup.Title</div>
                    }

                    <ul class="space-y-1">
                        @foreach (var link in sectionGroup.Links)
                        {
                            <li>
                                <a href="@Url.PathBaseAware(link.Href)"
                                   data-turbo-frame="doc-content"
                                   data-turbo-action="advance"
                                   class="block rounded-md px-2 py-1.5 text-sm font-medium transition-colors @(link.IsCurrent ? "bg-[#0d182a] text-[#bfdbfe]" : "text-slate-400 hover:bg-[#0d182a] hover:text-[#14b8a6]")"
                                   aria-current="@(link.IsCurrent ? "page" : null)">
                                    @link.Title
                                </a>

                                @await Html.PartialAsync("_DocSectionCompactChildren", link.Children)
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    </details>
}
