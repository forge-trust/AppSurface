<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <ImplicitUsings>enable</ImplicitUsings>
    <StaticWebAssetBasePath>_content/$(AssemblyName)</StaticWebAssetBasePath>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <ProjectReference Include="..\ForgeTrust.RazorWire\ForgeTrust.RazorWire.csproj" />
    <ProjectReference Include="..\ForgeTrust.AppSurface.Web.Tailwind\ForgeTrust.AppSurface.Web.Tailwind.csproj" />
    <ProjectReference Include="..\..\Caching\ForgeTrust.AppSurface.Caching\ForgeTrust.AppSurface.Caching.csproj" />
    <ProjectReference Include="..\..\Config\ForgeTrust.AppSurface.Config\ForgeTrust.AppSurface.Config.csproj" />
  </ItemGroup>

  <Import Project="..\ForgeTrust.AppSurface.Web.Tailwind\build\ForgeTrust.AppSurface.Web.Tailwind.targets" Condition="Exists('..\ForgeTrust.AppSurface.Web.Tailwind\build\ForgeTrust.AppSurface.Web.Tailwind.targets')" />

  <ItemGroup>
    <EmbeddedResource Include="wwwroot\css\site.gen.css" LogicalName="AppSurfaceDocsEmbeddedAssets/css/site.gen.css" />
    <EmbeddedResource Include="wwwroot\docs\appsurface-docs-icon.svg" LogicalName="AppSurfaceDocsEmbeddedAssets/docs/appsurface-docs-icon.svg" />
    <EmbeddedResource Include="wwwroot\docs\minisearch.min.js" LogicalName="AppSurfaceDocsEmbeddedAssets/docs/minisearch.min.js" />
    <EmbeddedResource Include="wwwroot\docs\outline-client.js" LogicalName="AppSurfaceDocsEmbeddedAssets/docs/outline-client.js" />
    <EmbeddedResource Include="wwwroot\docs\search-client.js" LogicalName="AppSurfaceDocsEmbeddedAssets/docs/search-client.js" />
    <EmbeddedResource Include="wwwroot\docs\search.css" LogicalName="AppSurfaceDocsEmbeddedAssets/docs/search.css" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="HtmlSanitizer" />
    <PackageReference Include="Markdig" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
    <PackageReference Include="TextMateSharp" />
    <PackageReference Include="TextMateSharp.Grammars" />
    <PackageReference Include="YamlDotNet" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>ForgeTrust.AppSurface.Docs.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

</Project>
