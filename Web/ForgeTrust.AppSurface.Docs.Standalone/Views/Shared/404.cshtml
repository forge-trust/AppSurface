@using ForgeTrust.AppSurface.Docs
@using ForgeTrust.AppSurface.Docs.Models
@using ForgeTrust.AppSurface.Docs.Services
@using ForgeTrust.AppSurface.Web
@model BrowserStatusPageModel
@inject DocsRecoveryLinkBuilder DocsRecoveryLinkBuilder
@{
    Layout = null;
    var requestPath = string.IsNullOrWhiteSpace(Model.OriginalPath)
        ? "the requested documentation page"
        : Model.OriginalPath;
    var recoveryLinks = DocsRecoveryLinkBuilder.BuildRecoveryLinks();
    var primaryLink = recoveryLinks.First(link => link.Kind == DocsRecoveryLinkKind.Primary);
    var secondaryLinks = recoveryLinks.Where(link => link.Kind == DocsRecoveryLinkKind.Secondary).ToArray();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Documentation page not found</title>
    <style>
        :root {
            color-scheme: dark;
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            background: #0d182a;
            color: #eef4ff;
        }

        body {
            margin: 0;
            min-height: 100vh;
            background:
                linear-gradient(180deg, rgba(22, 37, 61, 0.92), rgba(13, 24, 42, 1) 42%),
                #0d182a;
            color: #eef4ff;
        }

        main {
            width: min(68rem, calc(100% - 2rem));
            margin: 0 auto;
            padding: clamp(2rem, 7vw, 5rem) 0;
        }

        .eyebrow {
            margin: 0 0 0.9rem;
            color: #7dd3fc;
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0;
            text-transform: uppercase;
        }

        h1 {
            max-width: 44rem;
            margin: 0 0 1rem;
            font-size: clamp(2.25rem, 4vw, 4.25rem);
            line-height: 1.02;
            letter-spacing: 0;
        }

        .summary {
            max-width: 45rem;
            margin: 0;
            color: #c8d7ee;
            font-size: 1.05rem;
            line-height: 1.7;
        }

        code {
            display: inline;
            padding: 0.12rem 0.35rem;
            border: 1px solid rgba(148, 163, 184, 0.35);
            border-radius: 0.35rem;
            background: rgba(15, 23, 42, 0.68);
            color: #ffffff;
            font-size: 0.95em;
            overflow-wrap: anywhere;
        }

        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.8rem;
            margin-top: 1.75rem;
        }

        .primary-action {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 2.75rem;
            padding: 0 1.1rem;
            border: 1px solid #7dd3fc;
            border-radius: 0.5rem;
            background: #7dd3fc;
            color: #07111f;
            font-weight: 700;
            text-decoration: none;
        }

        .primary-action:hover,
        .primary-action:focus-visible,
        .recovery-row:hover,
        .recovery-row:focus-visible {
            outline: 3px solid rgba(125, 211, 252, 0.38);
            outline-offset: 3px;
            text-decoration: none;
        }

        .browse {
            margin-top: clamp(2rem, 5vw, 3rem);
        }

        .browse h2 {
            margin: 0 0 0.9rem;
            color: #ffffff;
            font-size: 1rem;
            letter-spacing: 0;
        }

        .recovery-list {
            display: grid;
            gap: 0.75rem;
            max-width: 46rem;
        }

        .recovery-row {
            display: grid;
            grid-template-columns: minmax(8rem, 11rem) 1fr;
            gap: 1rem;
            min-height: 3.5rem;
            padding: 0.95rem 1rem;
            border: 1px solid rgba(148, 163, 184, 0.28);
            border-radius: 0.5rem;
            background: rgba(15, 23, 42, 0.54);
            color: #dbeafe;
            text-decoration: none;
        }

        .recovery-title {
            color: #ffffff;
            font-weight: 800;
        }

        .recovery-description {
            color: #adc3df;
            line-height: 1.45;
        }

        @@media (max-width: 42rem) {
            main {
                padding-top: 2rem;
            }

            .actions,
            .primary-action {
                width: 100%;
            }

            .recovery-row {
                grid-template-columns: 1fr;
                gap: 0.3rem;
            }
        }
    </style>
</head>
<body>
<main>
    <p class="eyebrow">AppSurface Docs</p>
    <h1>Documentation page not found</h1>
    <p class="summary">We couldn't open <code>@requestPath</code>. The page may have moved, or the link may point at an older docs route.</p>
    <nav class="actions" aria-label="Documentation recovery actions">
        <a class="primary-action" href="@Url.PathBaseAware(primaryLink.Href)">@primaryLink.Title</a>
    </nav>
    <section class="browse" aria-labelledby="browse-heading">
        <h2 id="browse-heading">Browse trusted entry points</h2>
        <div class="recovery-list">
            @foreach (var link in secondaryLinks)
            {
                <a class="recovery-row" href="@Url.PathBaseAware(link.Href)" data-rw-export-ignore="@(link.IgnoreDuringStaticExport ? "true" : null)">
                    <span class="recovery-title">@link.Title</span>
                    <span class="recovery-description">@link.Description</span>
                </a>
            }
        </div>
    </section>
</main>
</body>
</html>
