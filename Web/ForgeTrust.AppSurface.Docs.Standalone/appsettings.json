{
  "RazorDocs": {
    "Harvest": {
      "Paths": {
        "IncludeGlobs": [
          "README.md",
          "LICENSE",
          "Aspire/**/README.md",
          "Caching/**/README.md",
          "Cli/**/README.md",
          "Config/**/README.md",
          "Console/**/README.md",
          "Dependency/**/README.md",
          "ForgeTrust.AppSurface.Core/README.md",
          "packages/**/README.md",
          "Web/ForgeTrust.AppSurface.Docs/*.md",
          "Web/**/README.md",
          "Web/**/Docs/**/*.md",
          "releases/**/*.md",
          "start-here/**/*.md",
          "guides/**/*.md",
          "concepts/**/*.md",
          "troubleshooting/**/*.md",
          "examples/**/README.md",
          "**/*.cs"
        ],
        "ExcludeGlobs": [
          "**/TestResults/**",
          "**/generated/**"
        ]
      }
    }
  }
}
