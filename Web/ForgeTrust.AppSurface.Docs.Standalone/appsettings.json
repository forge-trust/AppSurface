{
  "RazorDocs": {
    "Harvest": {
      "Paths": {
        "IncludeGlobs": [
          "README.md",
          "LICENSE",
          "packages/**/README.md",
          "Web/**/README.md",
          "Web/**/Docs/**/*.md",
          "releases/**/*.md",
          "start-here/**/*.md",
          "guides/**/*.md",
          "concepts/**/*.md",
          "troubleshooting/**/*.md",
          "examples/**/README.md",
          "**/*.cs"
        ],
        "ExcludeGlobs": [
          "**/TestResults/**",
          "**/generated/**"
        ]
      }
    }
  }
}
