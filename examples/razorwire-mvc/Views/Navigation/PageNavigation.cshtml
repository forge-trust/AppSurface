@{
    ViewData["Title"] = "Page Navigation";
}

<style>
    .brochure-section {
        min-height: calc(100svh - 10rem);
        scroll-margin-top: 16rem;
    }

    .brochure-page-nav {
        position: sticky;
        top: 4rem;
        z-index: 40;
        margin-inline: -1rem;
        padding: 0.75rem 1rem;
        background: linear-gradient(180deg, rgb(248 250 252 / 0.98), rgb(248 250 252 / 0.9));
        backdrop-filter: blur(12px);
    }

    .brochure-page-nav [data-rw-page-nav-panel] {
        display: flex;
        gap: 0.5rem;
        padding-top: 0.75rem;
        transition: max-height 160ms ease, opacity 160ms ease;
    }

    .brochure-page-nav [data-rw-page-nav-panel-state="open"] {
        flex-wrap: wrap;
        max-height: 12rem;
        overflow: visible;
    }

    .brochure-page-nav [data-rw-page-nav-enhanced="true"] [data-rw-page-nav-panel-state="closed"] {
        position: absolute;
        top: 2.55rem;
        right: 4.75rem;
        left: 1.55rem;
        z-index: 1;
        display: block;
        max-height: 1.35rem;
        opacity: 1;
        padding-top: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .brochure-page-nav [data-rw-page-nav-enhanced="true"] [data-rw-page-nav-toggle][aria-expanded="false"] .brochure-page-nav-toggle-copy-closed {
        visibility: hidden;
    }

    .brochure-page-nav [data-rw-page-nav-enhanced="true"] [data-rw-page-nav-panel-state="closed"] [data-rw-page-nav-link] {
        display: none;
    }

    .brochure-page-nav [data-rw-page-nav-enhanced="true"] [data-rw-page-nav-panel-state="closed"] [data-rw-page-nav-active="true"] {
        display: block;
        max-width: 100%;
        overflow: hidden;
        border: 0;
        background: transparent;
        padding: 0;
        color: rgb(51 65 85);
        box-shadow: none;
        font-size: 0.875rem;
        font-weight: 500;
        line-height: 1.25rem;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .brochure-page-nav [data-rw-page-nav-enhanced="true"] [data-rw-page-nav-panel-state="closed"] [data-rw-page-nav-active="true"]::after {
        display: none;
    }

    .brochure-page-nav [data-rw-page-nav-link] {
        flex: 0 0 auto;
        white-space: nowrap;
    }

    .brochure-page-nav [data-rw-page-nav-active="true"] {
        border-color: rgb(79 70 229);
        background: rgb(238 242 255);
        color: rgb(67 56 202);
        box-shadow: inset 0 -2px 0 rgb(79 70 229), 0 10px 24px rgb(79 70 229 / 0.12);
    }

    .brochure-page-nav [data-rw-page-nav-active="true"]::after {
        content: "";
        display: inline-block;
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 9999px;
        background: rgb(79 70 229);
    }

    .brochure-page-nav [data-rw-page-nav-toggle][aria-expanded="true"] .brochure-page-nav-toggle-icon {
        transform: rotate(180deg);
    }

    .brochure-page-nav-toggle-copy-open {
        display: none;
    }

    .brochure-page-nav [data-rw-page-nav-toggle][aria-expanded="true"] .brochure-page-nav-toggle-copy-open {
        display: block;
    }

    .brochure-page-nav [data-rw-page-nav-toggle][aria-expanded="true"] .brochure-page-nav-toggle-copy-closed {
        display: none;
    }

    @@media (min-width: 768px) {
        .brochure-section {
            scroll-margin-top: 15rem;
        }
    }

    @@media (min-width: 1024px) {
        .brochure-section {
            min-height: calc(100vh - 9rem);
            scroll-margin-top: 8rem;
        }

        .brochure-page-nav {
            top: 6rem;
            margin-inline: 0;
            padding: 0;
            background: transparent;
            backdrop-filter: none;
        }

        .brochure-page-nav [data-rw-page-nav-panel] {
            display: block;
            position: static;
            opacity: 1;
            pointer-events: auto;
            overflow: visible;
            max-height: none;
            padding-bottom: 0;
            padding-top: 0;
            mask-image: none;
        }

        .brochure-page-nav [data-rw-page-nav-enhanced="true"] [data-rw-page-nav-panel-state="closed"] {
            max-height: none;
            opacity: 1;
            position: static;
            overflow: visible;
            pointer-events: auto;
        }

        .brochure-page-nav [data-rw-page-nav-panel-state="closed"] [data-rw-page-nav-link] {
            display: flex;
        }

        .brochure-page-nav [data-rw-page-nav-link] {
            width: 100%;
            white-space: normal;
        }

        .brochure-page-nav [data-rw-page-nav-active="true"] {
            box-shadow: inset 4px 0 0 rgb(79 70 229), 0 10px 24px rgb(79 70 229 / 0.12);
        }
    }
</style>

<div class="space-y-8 lg:grid lg:grid-cols-[18rem_1fr] lg:gap-8 lg:space-y-0">
    <header class="rounded-lg border border-slate-200 bg-white p-8 shadow-sm lg:col-start-2">
        <p class="text-sm font-semibold uppercase text-indigo-600">RazorWire behavior</p>
        <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950">Page navigation without brochure-site JavaScript</h1>
        <p class="mt-4 max-w-2xl text-lg text-slate-600">
            This page uses normal anchors, normal sections, RazorWire data attributes, and app-owned CSS. RazorWire owns the active state, hash updates, and optional mobile panel close.
        </p>
    </header>

    <aside class="brochure-page-nav lg:col-start-1 lg:row-start-1 lg:self-start">
        <nav rw-page-nav
             class="relative rounded-xl border border-slate-200 bg-white/95 p-3 shadow-lg shadow-slate-900/5 ring-1 ring-white"
             aria-label="Brochure page sections">
            <button rw-page-nav-toggle="brochure-sections-panel"
                    class="flex w-full items-center justify-between gap-3 rounded-lg border border-slate-200 bg-white px-3 py-2.5 text-left text-sm text-slate-700 transition-colors hover:border-indigo-200 hover:bg-indigo-50 lg:hidden"
                    aria-expanded="false">
                <span>
                    <span class="block text-[0.7rem] font-semibold uppercase tracking-wide text-slate-500">Sections</span>
                    <span class="brochure-page-nav-toggle-copy-closed block font-medium text-slate-700">Page navigation</span>
                    <span class="brochure-page-nav-toggle-copy-open font-medium text-slate-900">Choose a section</span>
                </span>
                <span class="brochure-page-nav-toggle-icon grid h-8 w-8 place-items-center rounded-full bg-white text-slate-500 shadow-sm transition-transform" aria-hidden="true">⌄</span>
            </button>
            <div id="brochure-sections-panel"
                 rw-page-nav-panel
                 class="lg:space-y-2"
                 data-rw-page-nav-panel-state="closed">
                <a rw-page-nav-link
                   class="flex items-center justify-between gap-3 rounded-full border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-600 shadow-sm transition-colors hover:border-indigo-200 hover:bg-indigo-50 lg:rounded-lg lg:border-transparent lg:bg-transparent lg:shadow-none lg:hover:border-slate-200 lg:hover:bg-slate-50"
                   href="#trust">Trust Signals</a>
                <a rw-page-nav-link
                   class="flex items-center justify-between gap-3 rounded-full border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-600 shadow-sm transition-colors hover:border-indigo-200 hover:bg-indigo-50 lg:rounded-lg lg:border-transparent lg:bg-transparent lg:shadow-none lg:hover:border-slate-200 lg:hover:bg-slate-50"
                   href="#workflow">Buyer Workflow</a>
                <a rw-page-nav-link
                   class="flex items-center justify-between gap-3 rounded-full border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-600 shadow-sm transition-colors hover:border-indigo-200 hover:bg-indigo-50 lg:rounded-lg lg:border-transparent lg:bg-transparent lg:shadow-none lg:hover:border-slate-200 lg:hover:bg-slate-50"
                   href="#state">Live Scroll State</a>
                <a rw-page-nav-link
                   class="flex items-center justify-between gap-3 rounded-full border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-600 shadow-sm transition-colors hover:border-indigo-200 hover:bg-indigo-50 lg:rounded-lg lg:border-transparent lg:bg-transparent lg:shadow-none lg:hover:border-slate-200 lg:hover:bg-slate-50"
                   href="#replacement">Runtime Ownership</a>
                <a rw-page-nav-link
                   class="flex items-center justify-between gap-3 rounded-full border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-600 shadow-sm transition-colors hover:border-indigo-200 hover:bg-indigo-50 lg:rounded-lg lg:border-transparent lg:bg-transparent lg:shadow-none lg:hover:border-slate-200 lg:hover:bg-slate-50"
                   href="#handoff">Host Styling</a>
            </div>
        </nav>
    </aside>

    <article class="space-y-8 lg:col-start-2">
        <section id="trust" class="brochure-section rounded-lg border border-slate-200 bg-white p-8 shadow-sm">
            <h2 class="text-2xl font-bold text-slate-950">Trust Signals</h2>
            <p class="mt-4 text-slate-600">
                A brochure page can keep its durable anchor URLs and still get active navigation state. Each link points at a section id, so the no-JavaScript path remains a plain browser jump.
            </p>
            <div class="mt-6 grid gap-4 sm:grid-cols-3">
                <div class="rounded-lg border border-slate-200 p-4">
                    <div class="text-2xl font-bold text-slate-950">0</div>
                    <p class="text-sm text-slate-500">Custom click handlers</p>
                </div>
                <div class="rounded-lg border border-slate-200 p-4">
                    <div class="text-2xl font-bold text-slate-950">3</div>
                    <p class="text-sm text-slate-500">Stable section links</p>
                </div>
                <div class="rounded-lg border border-slate-200 p-4">
                    <div class="text-2xl font-bold text-slate-950">1</div>
                    <p class="text-sm text-slate-500">Shared runtime owner</p>
                </div>
            </div>
            <div class="mt-10 rounded-lg border border-indigo-100 bg-indigo-50 p-6">
                <p class="text-sm font-semibold uppercase text-indigo-700">Visible state</p>
                <p class="mt-2 max-w-xl text-slate-700">
                    The side navigation highlights this section first, then follows the viewport as the page moves.
                </p>
            </div>
        </section>

        <section id="workflow" class="brochure-section rounded-lg border border-slate-200 bg-white p-8 shadow-sm">
            <h2 class="text-2xl font-bold text-slate-950">Buyer Workflow</h2>
            <p class="mt-4 text-slate-600">
                Mobile navigation can be a host-owned panel. The toggle and panel use normal ARIA attributes; RazorWire only mirrors open and closed state and closes the panel after successful same-page navigation.
            </p>
            <ol class="mt-6 space-y-3 text-slate-600">
                <li><strong class="text-slate-900">1.</strong> Keep ordinary section anchors in rendered HTML.</li>
                <li><strong class="text-slate-900">2.</strong> Add <code class="text-indigo-700">rw-page-nav-link</code> to same-page links.</li>
                <li><strong class="text-slate-900">3.</strong> Style <code class="text-indigo-700">data-rw-page-nav-active</code> in app CSS.</li>
            </ol>
            <div class="mt-10 grid gap-4 sm:grid-cols-2">
                <div class="rounded-lg border border-slate-200 p-4">
                    <p class="font-semibold text-slate-900">Hash entry</p>
                    <p class="mt-1 text-sm text-slate-600">Initial fragments activate the matching link on load.</p>
                </div>
                <div class="rounded-lg border border-slate-200 p-4">
                    <p class="font-semibold text-slate-900">Panel close</p>
                    <p class="mt-1 text-sm text-slate-600">Mobile panels close after same-page navigation succeeds.</p>
                </div>
            </div>
        </section>

        <section id="state" class="brochure-section rounded-lg border border-slate-200 bg-white p-8 shadow-sm">
            <h2 class="text-2xl font-bold text-slate-950">Live Scroll State</h2>
            <p class="mt-4 text-slate-600">
                Scroll events update the same active marker used by hash navigation. The nav item for this section becomes current once this block crosses the page threshold.
            </p>
            <div class="mt-8 grid gap-4 md:grid-cols-3">
                <div class="rounded-lg border border-slate-200 bg-slate-50 p-5">
                    <div class="text-sm font-semibold uppercase text-slate-500">State</div>
                    <p class="mt-3 text-lg font-semibold text-slate-950">aria-current</p>
                    <p class="mt-2 text-sm text-slate-600">Moves between links as the viewport changes.</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-slate-50 p-5">
                    <div class="text-sm font-semibold uppercase text-slate-500">Signal</div>
                    <p class="mt-3 text-lg font-semibold text-slate-950">data attribute</p>
                    <p class="mt-2 text-sm text-slate-600">Gives host CSS a stable active hook.</p>
                </div>
                <div class="rounded-lg border border-slate-200 bg-slate-50 p-5">
                    <div class="text-sm font-semibold uppercase text-slate-500">Fallback</div>
                    <p class="mt-3 text-lg font-semibold text-slate-950">plain anchors</p>
                    <p class="mt-2 text-sm text-slate-600">Remain useful when JavaScript is unavailable.</p>
                </div>
            </div>
        </section>

        <section id="replacement" class="brochure-section rounded-lg border border-slate-200 bg-white p-8 shadow-sm">
            <h2 class="text-2xl font-bold text-slate-950">Runtime Ownership</h2>
            <p class="mt-4 text-slate-600">
                RazorWire owns the navigation state and event binding. The host page owns the layout, labels, spacing, sticky offset, and active-link styling.
            </p>
            <dl class="mt-6 grid gap-4 sm:grid-cols-2">
                <div class="rounded-lg border border-slate-200 p-4">
                    <dt class="font-semibold text-slate-900">RazorWire</dt>
                    <dd class="mt-1 text-sm text-slate-600">Active links, hash changes, lifecycle scans, and optional panel close.</dd>
                </div>
                <div class="rounded-lg border border-slate-200 p-4">
                    <dt class="font-semibold text-slate-900">Host app</dt>
                    <dd class="mt-1 text-sm text-slate-600">Section markup, responsive navigation chrome, and CSS for active state.</dd>
                </div>
            </dl>
        </section>

        <section id="handoff" class="brochure-section rounded-lg border border-slate-200 bg-white p-8 shadow-sm">
            <h2 class="text-2xl font-bold text-slate-950">Host Styling</h2>
            <p class="mt-4 text-slate-600">
                The sample styles active links with a left rail, subtle background, and status dot. Applications can replace that treatment without changing the RazorWire contract.
            </p>
            <div class="mt-8 rounded-lg border border-slate-200 bg-slate-50 p-6">
                <p class="max-w-2xl text-slate-700">
                    Sticky headers use ordinary CSS such as <code class="text-indigo-700">scroll-margin-top</code>, keeping layout decisions in the page where they belong.
                </p>
            </div>
        </section>
    </article>
</div>
