<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-50" style="scrollbar-gutter: stable;">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - RazorWire</title>
    <meta name="view-transition" content="same-origin"/>
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
    @* docs:snippet razorwire-scripts:start *@
    <rw:scripts/>
    @* docs:snippet razorwire-scripts:end *@
    <link rel="stylesheet" href="~/css/site.gen.css" asp-append-version="true"/>
    <script src="~/js/site.js" data-turbo-eval="false"></script>
</head>
<body class="h-full flex flex-col font-outfit text-slate-900 overflow-x-hidden">
<header class="fixed inset-x-0 top-0 z-[70] bg-white/80 backdrop-blur-md border-b border-slate-200">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
            <div class="flex items-center gap-8">
                <a class="text-xl font-bold bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent" asp-area="" asp-controller="Home" asp-action="Index">
                    RazorWire
                </a>
                <div class="hidden lg:flex gap-4">
                    <a class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors" asp-area="" asp-controller="Reactivity" asp-action="Index">Reactivity</a>
                    <a class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors" asp-area="" asp-controller="Reactivity" asp-action="FormFailures">Form Failures</a>
                    <a class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors" asp-area="" asp-controller="Navigation" asp-action="Index">Navigation</a>
                    <a class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors" asp-area="" asp-controller="Navigation" asp-action="PageNavigation">Page Nav</a>
                </div>
            </div>
            <details class="group relative">
                <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-lg border border-slate-200 bg-white text-slate-700 shadow-sm transition-colors hover:border-indigo-200 hover:bg-indigo-50 [&::-webkit-details-marker]:hidden">
                    <span class="sr-only">Site navigation</span>
                    <span class="relative block h-5 w-5" aria-hidden="true">
                        <span class="absolute left-0 top-1 block h-0.5 w-5 rounded-full bg-current transition-transform duration-150 group-open:top-1/2 group-open:-translate-y-1/2 group-open:rotate-45"></span>
                        <span class="absolute left-0 top-1/2 block h-0.5 w-5 -translate-y-1/2 rounded-full bg-current transition-opacity duration-150 group-open:opacity-0"></span>
                        <span class="absolute bottom-1 left-0 block h-0.5 w-5 rounded-full bg-current transition-transform duration-150 group-open:bottom-auto group-open:top-1/2 group-open:-translate-y-1/2 group-open:-rotate-45"></span>
                    </span>
                </summary>
                <div class="absolute right-0 top-12 z-[80] w-56 rounded-xl border border-slate-200 bg-white p-2 shadow-xl shadow-slate-900/10">
                    <a class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-700" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                    <a class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-700" asp-area="" asp-controller="Reactivity" asp-action="Index">Reactivity</a>
                    <a class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-700" asp-area="" asp-controller="Reactivity" asp-action="FormFailures">Form Failures</a>
                    <a class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-700" asp-area="" asp-controller="Navigation" asp-action="Index">Navigation</a>
                    <a class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-indigo-50 hover:text-indigo-700" asp-area="" asp-controller="Navigation" asp-action="PageNavigation">Page Nav</a>
                </div>
            </details>
        </div>
    </nav>
</header>

<main role="main" class="flex-grow pb-8 pt-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        @RenderBody()
    </div>
</main>

<footer class="border-t border-slate-200 bg-white py-6 mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center text-sm text-slate-500">
        <div>&copy; 2026 - RazorWire</div>
    </div>
</footer>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
