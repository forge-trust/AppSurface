<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - AppSurface PWA proof</title>
    <appsurface:pwa-head />
    <style>
        :root {
            color-scheme: light;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            color: #172033;
            background: #f7f8fb;
        }

        body {
            margin: 0;
        }

        main {
            max-width: 48rem;
            margin: 0 auto;
            padding: 4rem 1.25rem;
        }

        code {
            background: #e8edf7;
            border-radius: 0.25rem;
            padding: 0.125rem 0.25rem;
        }
    </style>
</head>
<body>
    @RenderBody()
</body>
</html>
