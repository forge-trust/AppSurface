@{
    ViewData["Title"] = "Install";
    var diagnosticsPath = Url.Content("~/_appsurface/pwa");
    var verifierUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.PathBase}";
}

<main>
    <h1>AppSurface PWA install proof</h1>
    <p>
        This page uses <code>&lt;appsurface:pwa-head /&gt;</code>, a generated manifest,
        development diagnostics, and an explicit offline fallback strategy.
    </p>
    <p>
        Open <a href="@diagnosticsPath">@diagnosticsPath</a> for local diagnostics, or run
        <code>appsurface pwa verify --url @verifierUrl</code>.
    </p>
</main>
